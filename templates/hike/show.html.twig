{% extends 'base.html.twig' %}

{% set cover_media = null %}
{% set fallback_cover_media = null %}

{% for mediaLink in hike.mediaLinks %}
    {% set media = mediaLink.mediaAsset %}

    {% if media and media.mediaType.value == 'image' %}
        {% if fallback_cover_media is null %}
            {% set fallback_cover_media = media %}
        {% endif %}

        {% if cover_media is null and mediaLink.role.value == 'cover' %}
            {% set cover_media = media %}
        {% endif %}
    {% endif %}
{% endfor %}

{% set cover_media = cover_media ?: fallback_cover_media %}

{% set cover_image = null %}

{% if cover_media %}
    {% set cover_image = media_image_url(cover_media, 'large') %}
{% endif %}

{% block title %}{{ hike.title }} - Randonnée{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ vite_entry_link_tags('assets/entries/public-detail.js') }}
    {{ vite_entry_link_tags('assets/entries/related-articles.js') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ vite_entry_script_tags('assets/entries/public-detail.js') }}
    {{ vite_entry_script_tags('assets/entries/related-articles.js') }}
{% endblock %}

{% block preloads %}
    {% if cover_image %}
        <link rel="preload" as="image" href="{{ cover_image }}">
    {% endif %}
{% endblock %}

{% block body %}
    <main class="public-detail-page">
        <section class="public-detail-hero">
            <div class="public-detail-container public-detail-hero-grid">
                <div>
                    <p class="public-detail-kicker">Randonnée</p>

                    <h1 class="public-detail-title">{{ hike.title }}</h1>

                    {% if hike.notes %}
                        <p class="public-detail-intro">{{ hike.notes|nl2br }}</p>
                    {% endif %}

                    {% include 'public_detail/_content_meta_badges.html.twig' with {
                        destination: hike.destination,
                        detected_commune_name: hike.detectedCommuneName,
                        detected_department_name: hike.detectedDepartmentName,
                        detected_region_name: hike.detectedRegionName,
                        points_count: hike.points|length
                    } only %}
                </div>

                <div
                    class="public-detail-cover"
                    {% if cover_image %}
                        style="--public-cover-image: url('{{ cover_image|e('html_attr') }}');"
                    {% endif %}
                    aria-label="Image principale de la randonnée"
                ></div>
            </div>
        </section>

        <section class="public-detail-content">
            <div class="public-detail-container">
                {% set gallery_id = 'hike-gallery-' ~ hike.id %}

                <div class="public-detail-layout">
                    {% include 'public_detail/_section_nav.html.twig' with {
                        entries: [
                            { label: 'Photos', href: '#' ~ gallery_id ~ '-photos' },
                            { label: 'Vidéos', href: '#' ~ gallery_id ~ '-videos' },
                            { label: 'Immersion', href: '#' ~ gallery_id ~ '-immersive' },
                            { label: 'Itinéraire', href: '#' ~ gallery_id ~ '-points' },
                            { label: 'Articles', href: '#hike-related-articles-' ~ hike.id }
                        ],
                        admin_subject: hike,
                        admin_edit_path: path('admin_studio_hike_edit', { id: hike.id })
                    } only %}

                    <div class="public-detail-main">
                        {% include 'public_detail/_media_sections.html.twig' with {
                            item: hike,
                            item_title: hike.title,
                            gallery_id: gallery_id,
                            photos_title: 'Photos du parcours',
                            photos_description: 'Les images classiques du lieu, utiles pour ressentir l’ambiance générale de la balade.',
                            video_kicker: 'Drone',
                            videos_title: 'Vidéos aériennes',
                            videos_description: 'Les vidéos prises pendant l’exploration permettent de visualiser le relief, les accès et l’ambiance du site.',
                            video_fallback_title: 'Vidéo du parcours',
                            points_title: 'Étapes de la randonnée',
                            gps_point_type: 'hike'
                        } only %}

                        {% include 'public_detail/_related_articles.html.twig' with {
                            article_links: hike.articleLinks,
                            section_title: 'Autour de cette balade',
                            modal_id_prefix: 'hike-related-article-' ~ hike.id,
                            section_id: 'hike-related-articles-' ~ hike.id
                        } only %}
                    </div>
                </div>
            </div>
        </section>
    </main>
{% endblock %}
