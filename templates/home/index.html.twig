{% extends 'layouts/home.html.twig' %}

{% block title %}Blog tourisme - randonnées, villes et destinations{% endblock %}

{% block meta_description %}
Découvrez des randonnées, villages, villes et paysages à travers un blog tourisme immersif.
{% endblock %}

{% block body %}
    <main class="travel-home">
        {% include 'home/partials/_hero.html.twig' with {
            latest_homepage_item: latest_homepage_item
        } only %}

        <section id="derniers-articles" class="home-destinations-section">
            <div class="home-container">
                <div class="home-section-header">
                    <div>
                        <p class="home-section-kicker">Dernières destinations</p>
                        <h2>Explorer les dernières destinations</h2>
                    </div>

                    <a class="home-outline-btn" href="{{ path('app_destination_index') }}">
                        Voir tout
                    </a>
                </div>

                <div class="home-destination-grid">
                    {% for destination_card in destination_cards|slice(0, 3) %}
                        {% include 'home/partials/_destination_card.html.twig' with {
                            destination: destination_card.destination,
                            representative_media: destination_card.media
                        } only %}
                    {% else %}
                        <p class="home-empty">Aucune destination disponible pour le moment.</p>
                    {% endfor %}
                </div>
            </div>
        </section>
    </main>
{% endblock %}
