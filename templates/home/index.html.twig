{% extends 'base.html.twig' %}

{% block title %}Blog tourisme - randonnées, villes et destinations méditerranéennes{% endblock %}

{% block meta_description %}
Découvrez des randonnées, villages, villes et paysages méditerranéens à travers un blog tourisme immersif.
{% endblock %}

{% block body %}
    <main class="travel-home">
        {% include 'home/partials/_hero.html.twig' with {
            latest_articles: latest_articles
        } only %}

        <section class="home-destinations-section">
            <div class="home-container">
                <div class="home-section-header">
                    <div>
                        <p class="home-section-kicker">Destinations populaires</p>
                        <h2>Explorer les derniers lieux visités</h2>
                    </div>

                    <a class="home-outline-btn" href="{{ path('app_destination_index') }}">
                        Voir tout
                    </a>
                </div>

                <div class="home-destination-grid">
                    {% for destination in discoverable_destinations|slice(0, 3) %}
                        {% include 'home/partials/_destination_card.html.twig' with {
                            destination: destination
                        } only %}
                    {% else %}
                        <p class="home-empty">Aucune destination disponible pour le moment.</p>
                    {% endfor %}
                </div>
            </div>
        </section>

        {% include 'home/partials/_newsletter.html.twig' only %}
    </main>
{% endblock %}