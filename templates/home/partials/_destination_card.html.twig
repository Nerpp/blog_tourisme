<a class="home-destination-card" href="{{ path('app_destination_show', { slug: destination.slug }) }}">
    <div class="home-destination-card__image {% if not representative_media %}home-destination-card__image--placeholder{% endif %}">
        {% if representative_media %}
            {% include 'public_detail/_responsive_image.html.twig' with {
                media: representative_media,
                alt: media_public_alt(representative_media, destination, destination.name),
                image_size: 'mobile',
                sizes: '(min-width: 1212px) 377px, (min-width: 961px) calc((100vw - 80px) / 3), (min-width: 701px) calc((100vw - 50px) / 2), calc(100vw - 24px)',
                img_class: 'home-destination-card__img'
            } only %}
        {% else %}
            <div class="home-destination-card__placeholder" aria-hidden="true"></div>
        {% endif %}

        <div class="home-destination-card__overlay">
            <span class="home-destination-card__chip">
                {{ destination.type.value }}
            </span>

            <h3>{{ destination.name }}</h3>

            <p>
                {% if representative_media %}
                    Découvrez les derniers contenus publiés autour de cette destination.
                {% else %}
                    Image à compléter pour cette destination.
                {% endif %}
            </p>
        </div>
    </div>
</a>
