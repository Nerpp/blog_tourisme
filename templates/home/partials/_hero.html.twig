<section class="home-hero">
    <div class="home-hero__overlay"></div>

    <div class="home-container home-hero__container">
        <div class="home-hero__content">
            <p class="home-kicker">Carnet d’exploration</p>

            <h1>
                Voyager entre mer, montagne et lumière méditerranéenne.
            </h1>

            <p class="home-hero__text">
                Découvrez des randonnées, villages et paysages méditerranéens
                à travers une approche immersive mêlant drone, photographie
                et exploration.
            </p>

            <div class="home-hero__actions">
                <a class="home-primary-btn" href="{{ path('app_article_index') }}">
                    Explorer les articles
                </a>

                <a class="home-secondary-btn" href="{{ path('app_destination_index') }}">
                    Voir les destinations
                </a>
            </div>
        </div>

        {% if latest_homepage_item %}
            <a
                class="home-latest-card"
                href="{{ latest_homepage_item.url }}"
                aria-label="Voir : {{ latest_homepage_item.title }}"
                {% if latest_homepage_item.image %}
                    style="--latest-card-image: url('{{ asset(latest_homepage_item.image)|e('html_attr') }}');"
                {% endif %}
            >
                <div class="home-latest-card__overlay">
                    <p>{{ latest_homepage_item.label }}</p>

                    <h2>{{ latest_homepage_item.title }}</h2>

                    <span class="home-latest-card__cta">
                        Découvrir
                    </span>
                </div>
            </a>
        {% else %}
            <aside class="home-latest-card">
                <div class="home-latest-card__overlay">
                    <p>Dernière publication</p>

                    <h2>Explorer les Pyrénées-Orientales</h2>

                    <span>Mer, montagne et villages méditerranéens</span>
                </div>
            </aside>
        {% endif %}
    </div>
</section>