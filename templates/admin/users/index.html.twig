{% extends 'admin/base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">Utilisateurs</h1>
            <p class="admin-subtitle">Suivi des comptes, avertissements et bannissements.</p>
        </div>
    </header>

    <section class="admin-card admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Nom affiché</th>
                    <th>Rôles</th>
                    <th>Trusted</th>
                    <th>Approuvés</th>
                    <th>Refusés</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.email }}</td>
                        <td>{{ user.displayName ?: '-' }}</td>
                        <td>{{ user.roles|join(', ') }}</td>
                        <td>{{ user.trustedCommenter ? 'Oui' : 'Non' }}</td>
                        <td>{{ user.approvedCommentsCount }}</td>
                        <td>{{ user.rejectedCommentsCount }}</td>
                        <td>
                            {% if user.banned %}
                                <span class="admin-badge admin-badge--danger">Utilisateur banni</span>
                            {% else %}
                                <span class="admin-badge">Compte actif</span>
                            {% endif %}
                        </td>
                        <td><a class="admin-button admin-button--small admin-button--secondary" href="{{ path('admin_users_show', { id: user.id }) }}">Ouvrir</a></td>
                    </tr>
                {% else %}
                    <tr><td colspan="8">Aucun utilisateur.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
