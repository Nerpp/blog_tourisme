{% extends 'admin/field_tool/base.html.twig' %}

{% block title %}{{ city_visit.title }}{% endblock %}

{% block topbar_action %}
    <a class="field-back" href="{{ admin_back_url }}">Retour outils terrain</a>
{% endblock %}

{% block body %}
    <section class="field-card">
        <h1 class="field-title">{{ city_visit.title }}</h1>
        <dl class="field-meta">
            <dt>Commune</dt>
            <dd>
                {% if city_visit.detectedCommuneName %}
                    {{ city_visit.detectedCommuneName }}{% if city_visit.detectedCommuneCode %} ({{ city_visit.detectedCommuneCode }}){% endif %}
                {% else %}
                    Non détectée
                {% endif %}
            </dd>
            <dt>Destination</dt>
            <dd>
                {% if city_visit.destination %}
                    {{ city_visit.destination.name }}
                {% elseif city_visit.detectedCommuneName %}
                    Commune détectée : {{ city_visit.detectedCommuneName }}, destination non trouvée dans la base.
                {% else %}
                    Non déterminée
                {% endif %}
            </dd>
            <dt>Statut</dt>
            <dd>{{ city_visit.status.value }}</dd>
        </dl>

        {% if city_visit.googleMapsUrl and point_count >= 2 %}
            <a class="field-button field-button--secondary" href="{{ city_visit.googleMapsUrl }}" target="_blank" rel="noopener noreferrer">
                Ouvrir dans Google Maps
            </a>
        {% endif %}
    </section>

    {% if errors is not empty %}
        <div class="field-alert">
            {% for error in errors %}
                <div>{{ error }}</div>
            {% endfor %}
        </div>
    {% endif %}

    {% if city_visit.status.value == 'draft' %}
        <section class="field-card">
            <form class="field-stack" method="post" action="{{ path('admin_quick_city_visit_point', { id: city_visit.id }) }}" data-gps-form>
                <input type="hidden" name="quick_city_visit_point[_token]" value="{{ csrf_token('quick_city_visit_point_' ~ city_visit.id) }}">
                <input type="hidden" name="quick_city_visit_point[latitude]" data-gps-latitude>
                <input type="hidden" name="quick_city_visit_point[longitude]" data-gps-longitude>
                <input type="hidden" name="quick_city_visit_point[accuracy]" data-gps-accuracy>

                <div class="field-row">
                    <label class="field-label" for="quick_city_visit_point_type">Type de point</label>
                    <select id="quick_city_visit_point_type" class="field-select" name="quick_city_visit_point[type]" data-gps-type>
                        {% for value, label in point_types %}
                            <option value="{{ value }}">{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="field-row">
                    <label class="field-label" for="quick_city_visit_point_title">Nom du point</label>
                    <input id="quick_city_visit_point_title" class="field-input" type="text" name="quick_city_visit_point[titlePoint]" placeholder="Optionnel">
                </div>

                <div class="field-row">
                    <label class="field-label" for="quick_city_visit_point_note">Note rapide</label>
                    <textarea id="quick_city_visit_point_note" class="field-textarea" name="quick_city_visit_point[note]" placeholder="Optionnel"></textarea>
                </div>

                <p class="field-status" data-gps-status aria-live="polite"></p>
                <button class="field-button" type="button" data-gps-submit>Ajouter ma position actuelle</button>
            </form>
        </section>

        <form method="post" action="{{ path('admin_quick_city_visit_finish', { id: city_visit.id }) }}">
            <input type="hidden" name="_token" value="{{ csrf_token('quick_city_visit_finish_' ~ city_visit.id) }}">
            <button class="field-button field-button--danger" type="submit">Terminer</button>
        </form>
    {% endif %}

    <section class="field-card">
        <h2 class="field-subtitle">Points ajoutés</h2>
        {% if city_visit.points is empty %}
            <p class="field-subtitle">Aucun point GPS enregistré.</p>
        {% else %}
            <ol class="field-points">
                {% for point in city_visit.points %}
                    <li class="field-point">
                        <div class="field-point__header">
                            <span>{{ point.position }}. {{ point.title ?: point.type.value }}</span>
                            <span>{{ point.type.value }}</span>
                        </div>
                        <div class="field-point__meta">
                            {{ point.latitude|number_format(6, '.', '') }}, {{ point.longitude|number_format(6, '.', '') }}
                            {% if point.accuracy is not null %}
                                · précision {{ point.accuracy|round }} m
                            {% endif %}
                        </div>
                        {% if point.detectedCommuneName %}
                            <div class="field-point__meta">
                                {{ point.detectedCommuneName }}{% if point.detectedDepartmentName %} · {{ point.detectedDepartmentName }}{% endif %}{% if point.detectedRegionName %} · {{ point.detectedRegionName }}{% endif %}
                            </div>
                        {% endif %}
                        {% if point.note %}
                            <div>{{ point.note|nl2br }}</div>
                        {% endif %}
                    </li>
                {% endfor %}
            </ol>
        {% endif %}
    </section>
{% endblock %}
