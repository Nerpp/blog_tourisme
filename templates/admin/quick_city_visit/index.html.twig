{% extends 'admin/field_tool/base.html.twig' %}

{% block title %}Nouvelle visite de ville rapide{% endblock %}

{% block body %}
    {% if current_destination %}
        <section class="field-card">
            <h1 class="field-title">Visite prête à créer</h1>
            <p class="field-subtitle">Cette destination sera utilisée pour créer un brouillon de visite. Vous pourrez ensuite ajouter les photos, les médias, la description et les informations depuis l’administration.</p>

            <form class="field-stack" method="post" action="{{ path('admin_quick_city_visit_start') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('quick_city_visit_start') }}">
                <input type="hidden" name="title" value="{{ default_title }}">
                <button class="field-button" type="submit">Créer la visite avec cette destination</button>
            </form>
        </section>

        {% include 'admin/_quick_destination_form.html.twig' with {
            ui_context: 'field',
            current_destination: current_destination,
            prepared_destination_postal_code: prepared_destination_postal_code,
            quick_destination_title: quick_destination_title,
            quick_destination_prepared_text: quick_destination_prepared_text,
            quick_destination_skip_action: quick_destination_skip_action,
            quick_destination_skip_token_id: quick_destination_skip_token_id,
            destination_quick_create: destination_quick_create,
            destination_type_options: destination_type_options,
            destination_parent_options: destination_parent_options
        } only %}
    {% else %}
        <section class="field-card">
            <h1 class="field-title">Démarrer sur le terrain</h1>
            <p class="field-subtitle">Utilisez ce mode si vous êtes sur place et voulez enregistrer les lieux à visiter avec votre position GPS.</p>

            <form class="field-stack" method="post" action="{{ path('admin_quick_city_visit_start') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('quick_city_visit_start') }}">
                <input type="hidden" name="title" value="{{ default_title }}">

                <div class="field-row">
                    <label class="field-label" for="quick_city_visit_notes">Note de visite</label>
                    <textarea id="quick_city_visit_notes" class="field-textarea" name="notes" placeholder="Optionnel"></textarea>
                </div>

                <button class="field-button" type="submit">Démarrer une visite de ville</button>
            </form>
        </section>

        <section class="field-card">
            <h1 class="field-title">Préparer une visite à distance</h1>
            <p class="field-subtitle">Choisissez une commune ou une destination, puis créez un brouillon à compléter dans l’administration.</p>
        </section>

        {% include 'admin/_quick_destination_form.html.twig' with {
            ui_context: 'field',
            current_destination: null,
            quick_destination_title: 'Choisir une destination',
            quick_destination_allow_skip: false,
            destination_quick_create: destination_quick_create,
            destination_type_options: destination_type_options,
            destination_parent_options: destination_parent_options
        } only %}
    {% endif %}
{% endblock %}
