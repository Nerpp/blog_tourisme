{% extends 'admin/base.html.twig' %}

{% block title %}Médias{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">Médias</h1>
            <p class="admin-subtitle">Inventaire clair des images et vidéos disponibles dans les Studios.</p>
        </div>
        <a class="admin-button" href="{{ path('admin_media_new') }}">Nouveau média</a>
    </header>

    <section class="admin-card admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Aperçu</th>
                    <th>Titre</th>
                    <th>Type de média</th>
                    <th>Type d’image ou vidéo</th>
                    <th>Fichier ou URL</th>
                    <th>Date d’ajout</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for media in media_assets %}
                    {% set src = media.filePath ?: media.thumbnailPath ?: media.externalUrl %}
                    {% set preview_src = src and (src starts with '/' or src starts with 'http') ? src : (src ? asset(src) : null) %}
                    <tr>
                        <td>
                            {% if media.mediaType.value == 'image' and preview_src %}
                                <img class="admin-media-thumb" src="{{ preview_src }}" alt="">
                            {% else %}
                                <span class="admin-badge admin-badge--muted">{{ media_type_labels[media.mediaType.value] }}</span>
                            {% endif %}
                        </td>
                        <td>{{ media.title ?: 'Sans titre' }}</td>
                        <td>{{ media_type_labels[media.mediaType.value] ?? media.mediaType.value }}</td>
                        <td>
                            {% if media.mediaType.value == 'image' %}
                                {{ media.imageType ? image_type_labels[media.imageType.value] : '-' }}
                            {% else %}
                                {{ media.videoType ? video_type_labels[media.videoType.value] : '-' }}
                            {% endif %}
                        </td>
                        <td>{{ media.filePath ?: media.externalUrl ?: '-' }}</td>
                        <td>{{ media.createdAt ? media.createdAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            <div class="admin-row-actions">
                                <a class="admin-button admin-button--small admin-button--secondary" href="{{ path('admin_media_edit', { id: media.id }) }}">Modifier</a>
                                <span class="admin-badge admin-badge--info">
                                    {{ media.articleLinks|length + media.placeLinks|length + media.hikeDraftLinks|length + media.cityVisitDraftLinks|length + media.hikePointLinks|length + media.cityVisitPointLinks|length }} utilisation(s)
                                </span>
                                <form method="post" action="{{ path('admin_media_delete', { id: media.id }) }}" onsubmit="return confirm('Supprimer ce média s’il n’est pas utilisé ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_media_delete_' ~ media.id) }}">
                                    <button class="admin-button admin-button--small admin-button--danger" type="submit">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7">Aucun média.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
