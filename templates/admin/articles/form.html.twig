{% extends 'admin/base.html.twig' %}

{% block admin_title %}{{ title }}{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">{{ title }}</h1>
            <p class="admin-subtitle">Rédigez une page SEO complète et reliez-la aux contenus touristiques du site.</p>
        </div>
        <div class="admin-row-actions">
            {% if article.id and article.slug is not empty and article.status.value == 'published' %}
                <a class="admin-button admin-button--secondary" href="{{ path('app_article_show', { slug: article.slug }) }}" target="_blank" rel="noopener noreferrer">Aperçu</a>
            {% endif %}
            <a class="admin-button admin-button--secondary" href="{{ path('admin_articles_index') }}">Retour</a>
        </div>
    </header>

    <form
        class="admin-form article-admin-form"
        method="post"
        enctype="multipart/form-data"
        data-article-admin-form
        data-article-saving-label="Enregistrement en cours…"
    >
        <input type="hidden" name="_token" value="{{ csrf_token(article.id ? 'admin_article_' ~ article.id : 'admin_article_form') }}">
        {% if article_submission_token is defined %}
            <input type="hidden" name="_submission_token" value="{{ article_submission_token }}">
        {% endif %}

        <div class="article-admin-layout">
            <div class="article-admin-main">
                <section class="admin-card article-admin-section">
                    <h2>Informations principales</h2>

                    <div class="admin-form-grid">
                        <div class="admin-field admin-field--full">
                            <label for="article-title">Titre</label>
                            <input id="article-title" name="title" value="{{ article.title }}" required>
                        </div>

                        <div class="admin-field admin-field--full">
                            <label for="article-excerpt">Résumé</label>
                            <textarea id="article-excerpt" name="excerpt" rows="4">{{ article.excerpt }}</textarea>
                        </div>
                    </div>
                </section>

                <section class="admin-card article-admin-section">
                    <h2>Contenu de l’article</h2>

                    <div class="admin-field">
                        <label for="article-content">Contenu</label>
                        <div class="article-editor-toolbar" aria-label="Outils de mise en forme">
                            <button type="button" data-article-editor-format="p">Paragraphe</button>
                            <button type="button" data-article-editor-format="h2">H2</button>
                            <button type="button" data-article-editor-format="h3">H3</button>
                            <button type="button" data-article-editor-command="bold">Gras</button>
                            <button type="button" data-article-editor-command="italic">Italique</button>
                            <button type="button" data-article-editor-command="insertUnorderedList">Liste</button>
                            <button type="button" data-article-editor-command="insertOrderedList">Liste numérotée</button>
                            <button type="button" data-article-editor-format="blockquote">Citation</button>
                            <button type="button" data-article-editor-link>Lien</button>
                        </div>
                        <div
                            class="article-rich-editor"
                            contenteditable="true"
                            data-article-editor
                        >{{ article_editor_content_html(article) }}</div>
                        <textarea
                            id="article-content"
                            class="article-editor-source"
                            name="content"
                            data-article-editor-source
                        >{{ article.content }}</textarea>
                        <span class="admin-muted">Mise en forme autorisée : titres, gras, italique, listes, citations, liens et images liées à l’article. Le HTML est nettoyé côté serveur.</span>
                    </div>
                </section>

                <section class="admin-card article-admin-section">
                    <h2>Images de l’article</h2>

                    <div class="admin-field">
                        <label for="article-gallery-images">Ajouter des images</label>
                        <input
                            id="article-gallery-images"
                            type="file"
                            name="galleryImages[]"
                            accept="image/jpeg,image/png,image/webp"
                            multiple
                            aria-describedby="article-gallery-images-help"
                            data-article-file-input="gallery"
                        >
                        <span id="article-gallery-images-help" class="admin-muted">Formats acceptés : JPG, PNG, WebP. Taille maximum : 30 Mo par photo. Les images sont renommées, nettoyées et optimisées automatiquement.</span>
                        <div class="article-upload-preview" data-article-file-preview="gallery" aria-live="polite"></div>
                        <input type="hidden" name="newCoverImageIndex" value="" data-article-new-cover-index>
                    </div>

                    {% set article_image_links = article.mediaLinks|filter(link => link.mediaAsset.mediaType.value == 'image') %}
                    {% set featured_image_is_linked = article.featuredImage and (article_image_links|filter(link => link.mediaAsset.id == article.featuredImage.id)|length > 0) %}

                    {% if article_image_links|length > 0 or (article.featuredImage and not featured_image_is_linked) %}
                        <div class="article-admin-media-list">
                            {% if article.featuredImage and not featured_image_is_linked %}
                                {% set media = article.featuredImage %}
                                {% set media_title = media_public_title(media, article, 'Image d’article') %}
                                <article class="article-admin-media-item is-main-media" data-main-media-card data-main-media-state="main">
                                    {% include 'public_detail/_responsive_image.html.twig' with {
                                        media: media,
                                        alt: media_public_alt(media, article, media_title),
                                        image_mode: 'card_thumbnail',
                                        img_class: 'article-admin-media-item__image',
                                        loading: 'lazy',
                                        decoding: 'async'
                                    } only %}
                                    <div>
                                        <strong>{{ media_title }}</strong>
                                        <span class="studio-media-role-badge" data-main-media-badge>Image principale</span>
                                        <code>[[media:{{ media.id }}]]</code>
                                        <div class="article-admin-media-actions">
                                            <button type="button" class="admin-button admin-button--secondary" data-article-insert-media="[[media:{{ media.id }}]]">Insérer</button>
                                            <label class="article-admin-cover-choice">
                                                <input type="radio" name="promoteCoverMedia" value="" checked data-article-cover-choice>
                                                Image principale
                                            </label>
                                            <label class="article-admin-check">
                                                <input
                                                    type="checkbox"
                                                    name="removeFeaturedImage"
                                                    value="{{ media.id }}"
                                                    data-article-delete-media
                                                    data-article-delete-message="Supprimer définitivement cette image de l’article ?&#10;Elle sera retirée du contenu et supprimée du serveur si elle n’est utilisée nulle part ailleurs."
                                                >
                                                Supprimer l’image
                                            </label>
                                            <span class="article-admin-delete-note">Elle sera retirée du contenu et supprimée du serveur si elle n’est utilisée nulle part ailleurs.</span>
                                        </div>
                                    </div>
                                </article>
                            {% endif %}
                            {% for media_link in article_image_links %}
                                {% set media = media_link.mediaAsset %}
                                {% set media_title = media_public_title(media, article, 'Image d’article') %}
                                {% set is_cover_image = media_link.role.value == 'cover' or (article.featuredImage and media.id and article.featuredImage.id == media.id) %}
                                <article
                                    class="article-admin-media-item {{ is_cover_image ? 'is-main-media' : '' }}"
                                    data-main-media-card
                                    data-main-media-state="{{ is_cover_image ? 'main' : 'gallery' }}"
                                >
                                    {% include 'public_detail/_responsive_image.html.twig' with {
                                        media: media,
                                        alt: media_public_alt(media, article, media_title),
                                        image_mode: 'card_thumbnail',
                                        img_class: 'article-admin-media-item__image',
                                        loading: 'lazy',
                                        decoding: 'async'
                                    } only %}

                                    <div>
                                        <strong>{{ media_title }}</strong>
                                        <span class="studio-media-role-badge" data-main-media-badge>
                                            {{ is_cover_image ? 'Image principale' : 'Galerie générale' }}
                                        </span>
                                        <code>[[media:{{ media.id }}]]</code>
                                        <div class="article-admin-media-actions">
                                            <button type="button" class="admin-button admin-button--secondary" data-article-insert-media="[[media:{{ media.id }}]]">
                                                Insérer
                                            </button>
                                            <label class="article-admin-cover-choice">
                                                <input
                                                    type="radio"
                                                    name="promoteCoverMedia"
                                                    value="{{ is_cover_image ? '' : media_link.id }}"
                                                    {% if is_cover_image %}checked{% endif %}
                                                    data-article-cover-choice
                                                >
                                                {{ is_cover_image ? 'Image principale' : 'Définir comme image principale' }}
                                            </label>
                                            <label class="article-admin-check">
                                                <input
                                                    type="checkbox"
                                                    name="removeMediaLinks[]"
                                                    value="{{ media_link.id }}"
                                                    data-article-delete-media
                                                    data-article-delete-message="Supprimer définitivement cette image de l’article ?&#10;Elle sera retirée du contenu et supprimée du serveur si elle n’est utilisée nulle part ailleurs."
                                                >
                                                Supprimer l’image
                                            </label>
                                            <span class="article-admin-delete-note">
                                                Elle sera retirée du contenu et supprimée du serveur si elle n’est utilisée nulle part ailleurs.
                                            </span>
                                        </div>
                                    </div>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                </section>
            </div>

            <aside class="article-admin-sidebar">
                <section class="admin-card article-admin-section">
                    <h2>Publication</h2>

                    <div class="admin-field">
                        <label for="article-status">Statut</label>
                        <select id="article-status" name="status">
                            {% for value, label in status_options %}
                                <option value="{{ value }}" {% if article.status.value == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="admin-field">
                        <label for="article-category">Catégorie</label>
                        <select id="article-category" name="category">
                            <option value="">Non renseignée</option>
                            {% for category in categories %}
                                <option value="{{ category.id }}" {% if article.category and article.category.id == category.id %}selected{% endif %}>{{ category.name }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {% if article.slug %}
                        <p class="admin-muted">URL : /articles/{{ article.slug }}</p>
                    {% endif %}
                </section>

                <section class="admin-card article-admin-section">
                    <h2>Lien avec le site</h2>

                    <div class="admin-field">
                        <label for="article-linked-type">Type de contenu lié</label>
                        <select id="article-linked-type" name="linkedContentType" data-article-link-type>
                            <option value="none" {% if selected_link_type == 'none' %}selected{% endif %}>Aucun lien pour le moment</option>
                            <option value="hike" {% if selected_link_type == 'hike' %}selected{% endif %}>Randonnée</option>
                            <option value="city_visit" {% if selected_link_type == 'city_visit' %}selected{% endif %}>Visite de ville</option>
                        </select>
                    </div>

                    <div class="admin-field" data-article-link-panel="hike">
                        <label for="article-hike-search">Randonnée</label>
                        <div
                            class="admin-autocomplete"
                            data-admin-autocomplete
                            data-empty-label="Aucune randonnée trouvée"
                        >
                            <input type="hidden" name="linkedHike" value="{{ selected_hike_id }}" data-admin-autocomplete-value>
                            <input
                                id="article-hike-search"
                                type="search"
                                placeholder="Rechercher une randonnée…"
                                autocomplete="off"
                                data-admin-autocomplete-input
                            >
                            <div class="admin-autocomplete__selection" data-admin-autocomplete-selection hidden></div>
                            <div class="admin-autocomplete__results" data-admin-autocomplete-results hidden></div>
                            {% for hike in hike_options %}
                                {% set is_automatic_hike_title = hike.title starts with 'Randonnée du ' %}
                                {% set label = hike.title ~ (hike.destination ? ' — ' ~ hike.destination.name : '') ~ (is_automatic_hike_title ? ' — titre automatique' : '') %}
                                <button
                                    type="button"
                                    class="admin-autocomplete__option"
                                    data-admin-autocomplete-option
                                    data-id="{{ hike.id }}"
                                    data-label="{{ label|e('html_attr') }}"
                                    data-search="{{ (label ~ ' ' ~ (hike.destination ? hike.destination.name : ''))|lower|e('html_attr') }}"
                                    hidden
                                >{{ label }}</button>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="admin-field" data-article-link-panel="city_visit">
                        <label for="article-city-visit-search">Visite de ville</label>
                        <div
                            class="admin-autocomplete"
                            data-admin-autocomplete
                            data-empty-label="Aucune visite trouvée"
                        >
                            <input type="hidden" name="linkedCityVisit" value="{{ selected_city_visit_id }}" data-admin-autocomplete-value>
                            <input
                                id="article-city-visit-search"
                                type="search"
                                placeholder="Rechercher une visite de ville…"
                                autocomplete="off"
                                data-admin-autocomplete-input
                            >
                            <div class="admin-autocomplete__selection" data-admin-autocomplete-selection hidden></div>
                            <div class="admin-autocomplete__results" data-admin-autocomplete-results hidden></div>
                            {% for city_visit in city_visit_options %}
                                {% set is_automatic_city_visit_title = city_visit.title starts with 'Visite de ville du ' %}
                                {% set label = city_visit.title ~ (city_visit.destination ? ' — ' ~ city_visit.destination.name : '') ~ (is_automatic_city_visit_title ? ' — titre automatique' : '') %}
                                <button
                                    type="button"
                                    class="admin-autocomplete__option"
                                    data-admin-autocomplete-option
                                    data-id="{{ city_visit.id }}"
                                    data-label="{{ label|e('html_attr') }}"
                                    data-search="{{ (label ~ ' ' ~ (city_visit.destination ? city_visit.destination.name : ''))|lower|e('html_attr') }}"
                                    hidden
                                >{{ label }}</button>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="admin-field">
                        <label for="article-role">Type d’article</label>
                        <select id="article-role" name="articleRole">
                            {% for value, label in role_options %}
                                <option value="{{ value }}" {% if selected_article_role == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </section>

                <div class="admin-actions">
                    <button class="admin-button" type="submit" data-article-submit-button>
                        <span data-article-submit-label>{{ submit_label }}</span>
                        <span class="admin-button__spinner" aria-hidden="true"></span>
                    </button>
                    <a class="admin-button admin-button--secondary" href="{{ path('admin_articles_index') }}">Annuler</a>
                    <span class="article-admin-submit-status" data-article-submit-status aria-live="polite"></span>
                </div>
            </aside>
        </div>
    </form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            const typeSelect = document.querySelector('[data-article-link-type]');
            const panels = document.querySelectorAll('[data-article-link-panel]');
            const autocompletes = document.querySelectorAll('[data-admin-autocomplete]');

            if (!typeSelect || panels.length === 0) {
                return;
            }

            const clearAutocomplete = (autocomplete) => {
                const hiddenInput = autocomplete.querySelector('[data-admin-autocomplete-value]');
                const searchInput = autocomplete.querySelector('[data-admin-autocomplete-input]');
                const selection = autocomplete.querySelector('[data-admin-autocomplete-selection]');
                const results = autocomplete.querySelector('[data-admin-autocomplete-results]');

                hiddenInput.value = '';
                searchInput.value = '';
                selection.hidden = true;
                selection.textContent = '';
                results.hidden = true;
                results.replaceChildren();
            };

            const refreshPanels = () => {
                panels.forEach((panel) => {
                    const isActive = panel.dataset.articleLinkPanel === typeSelect.value;
                    panel.hidden = !isActive;
                    panel.querySelectorAll('input').forEach((input) => {
                        input.disabled = !isActive;
                    });
                    if (!isActive) {
                        panel.querySelectorAll('[data-admin-autocomplete]').forEach(clearAutocomplete);
                    }
                });
            };

            autocompletes.forEach((autocomplete) => {
                const hiddenInput = autocomplete.querySelector('[data-admin-autocomplete-value]');
                const searchInput = autocomplete.querySelector('[data-admin-autocomplete-input]');
                const results = autocomplete.querySelector('[data-admin-autocomplete-results]');
                const selection = autocomplete.querySelector('[data-admin-autocomplete-selection]');
                const options = Array.from(autocomplete.querySelectorAll('[data-admin-autocomplete-option]'));
                const emptyLabel = autocomplete.dataset.emptyLabel || 'Aucun résultat';

                const selectOption = (option) => {
                    hiddenInput.value = option.dataset.id;
                    searchInput.value = '';
                    selection.hidden = false;
                    selection.textContent = option.dataset.label;
                    results.hidden = true;
                    results.replaceChildren();
                };

                const renderResults = () => {
                    const query = searchInput.value.trim().toLowerCase();
                    results.replaceChildren();

                    if (query === '') {
                        results.hidden = true;
                        return;
                    }

                    const matches = options
                        .filter((option) => option.dataset.search.includes(query))
                        .slice(0, 10);

                    if (matches.length === 0) {
                        const empty = document.createElement('p');
                        empty.className = 'admin-autocomplete__empty';
                        empty.textContent = emptyLabel;
                        results.append(empty);
                        results.hidden = false;
                        return;
                    }

                    matches.forEach((option) => {
                        const button = document.createElement('button');
                        button.type = 'button';
                        button.className = 'admin-autocomplete__result';
                        button.textContent = option.dataset.label;
                        button.addEventListener('click', () => selectOption(option));
                        results.append(button);
                    });

                    results.hidden = false;
                };

                const preselected = options.find((option) => option.dataset.id === hiddenInput.value);
                if (preselected) {
                    selectOption(preselected);
                }

                searchInput.addEventListener('input', () => {
                    hiddenInput.value = '';
                    selection.hidden = true;
                    selection.textContent = '';
                    renderResults();
                });

                searchInput.addEventListener('focus', renderResults);
            });

            typeSelect.addEventListener('change', refreshPanels);
            refreshPanels();
        })();

        (() => {
            const editor = document.querySelector('[data-article-editor]');
            const source = document.querySelector('[data-article-editor-source]');
            const form = document.querySelector('.article-admin-form');

            if (!editor || !source || !form) {
                return;
            }

            const syncSource = () => {
                source.value = editor.innerHTML.trim();
            };

            const focusEditor = () => {
                editor.focus();
            };

            document.querySelectorAll('[data-article-editor-command]').forEach((button) => {
                button.addEventListener('click', () => {
                    focusEditor();
                    document.execCommand(button.dataset.articleEditorCommand, false);
                    syncSource();
                });
            });

            document.querySelectorAll('[data-article-editor-format]').forEach((button) => {
                button.addEventListener('click', () => {
                    focusEditor();
                    document.execCommand('formatBlock', false, button.dataset.articleEditorFormat);
                    syncSource();
                });
            });

            document.querySelectorAll('[data-article-editor-link]').forEach((button) => {
                button.addEventListener('click', () => {
                    const href = window.prompt('URL du lien');
                    if (!href) {
                        return;
                    }

                    focusEditor();
                    document.execCommand('createLink', false, href);
                    syncSource();
                });
            });

            document.querySelectorAll('[data-article-insert-media]').forEach((button) => {
                button.addEventListener('click', () => {
                    focusEditor();
                    document.execCommand('insertText', false, ` ${button.dataset.articleInsertMedia} `);
                    syncSource();
                });
            });

            editor.addEventListener('input', syncSource);
            form.addEventListener('submit', syncSource);
            syncSource();
        })();
    </script>
{% endblock %}
