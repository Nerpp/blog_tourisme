{% extends 'admin/base.html.twig' %}

{% block admin_title %}Articles{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">Articles</h1>
            <p class="admin-subtitle">Retrouvez, organisez, archivez ou supprimez les articles.</p>
        </div>
        <div class="admin-row-actions">
            <a class="admin-button admin-button--secondary" href="{{ path('admin_article_categories_index') }}">Catégories</a>
            <a class="admin-button" href="{{ path('admin_articles_new') }}">Nouvel article</a>
        </div>
    </header>

    <section class="admin-card admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Statut</th>
                    <th>Catégorie</th>
                    <th>Auteur</th>
                    <th>Publication</th>
                    <th>Modification</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for article in articles %}
                    <tr>
                        <td>{{ article.title }}</td>
                        <td><span class="admin-badge">{{ status_labels[article.status.value] ?? article.status.value }}</span></td>
                        <td>{{ article.category ?: 'Non renseignée' }}</td>
                        <td>{{ article.author ?: '-' }}</td>
                        <td>{{ article.publishedAt ? article.publishedAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>{{ article.updatedAt ? article.updatedAt|date('d/m/Y H:i') : '-' }}</td>
                        <td>
                            <div class="admin-row-actions">
                                <a class="admin-button admin-button--small admin-button--secondary" href="{{ path('admin_articles_edit', { id: article.id }) }}">Modifier</a>
                                {% if article.slug is not empty and article.status.value == 'published' %}
                                    <a class="admin-button admin-button--small admin-button--secondary" href="{{ path('app_article_show', { slug: article.slug }) }}" target="_blank" rel="noopener noreferrer">Aperçu</a>
                                {% endif %}
                                <form method="post" action="{{ path('admin_articles_archive', { id: article.id }) }}" onsubmit="return confirm('Archiver cet article ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_article_archive_' ~ article.id) }}">
                                    <button class="admin-button admin-button--small admin-button--secondary" type="submit">Archiver</button>
                                </form>
                                {% set delete_confirmation = 'Supprimer définitivement l’article « ' ~ article.title ~ ' » ? Cette action est irréversible. Le contenu de l’article sera supprimé. Ses illustrations propres seront supprimées du serveur si elles ne sont utilisées nulle part ailleurs. Les médias partagés avec un autre contenu seront conservés.' %}
                                <form method="post" action="{{ path('admin_articles_delete', { id: article.id }) }}" onsubmit="return confirm('{{ delete_confirmation|e('js') }}');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_article_delete_' ~ article.id) }}">
                                    <button class="admin-button admin-button--small admin-button--danger" type="submit">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7">Aucun article.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </section>
{% endblock %}
