{% extends 'admin/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block stylesheets %}
    {% if app.environment != 'test' %}
        {{ vite_entry_link_tags('assets/js/prevision-destination-map.js') }}
    {% endif %}
    <style>
        .prevision-form-layout,
        .prevision-form-section,
        .prevision-search-results,
        .prevision-point-tools,
        .prevision-map-links {
            display: grid;
            gap: 12px;
        }

        .prevision-form-section {
            padding-top: 4px;
        }

        .prevision-form-section h2 {
            margin: 0;
            font-size: 1.1rem;
        }

        .prevision-search-result {
            display: block;
            width: 100%;
            padding: 10px;
            border: 1px solid var(--admin-line);
            border-radius: var(--admin-radius);
            background: #fff;
            color: var(--admin-text);
            cursor: pointer;
            font: inherit;
            text-align: left;
        }

        .prevision-search-result:hover,
        .prevision-search-result:focus-visible {
            border-color: var(--admin-primary);
            background: var(--admin-primary-soft);
            color: var(--admin-primary);
        }

        .prevision-map {
            min-height: 360px;
            overflow: hidden;
            border: 1px solid var(--admin-line);
            border-radius: var(--admin-radius);
            background: #eef1ee;
        }

        .prevision-map-status {
            min-height: 22px;
            margin: 0;
        }

        .prevision-map-links {
            grid-template-columns: repeat(auto-fit, minmax(180px, max-content));
        }

        .prevision-map-link[aria-disabled="true"] {
            pointer-events: none;
        }

        .prevision-submit-help {
            margin: 0;
            color: var(--admin-muted);
        }
    </style>
{% endblock %}

{% block body %}
    {% set has_coordinates = prevision_destination.latitude is not null and prevision_destination.longitude is not null %}
    {% set maps_url = has_coordinates ? 'https://www.google.com/maps?q=' ~ prevision_destination.latitude|number_format(7, '.', '') ~ ',' ~ prevision_destination.longitude|number_format(7, '.', '') : '#' %}
    {% set osm_url = has_coordinates ? 'https://www.openstreetmap.org/?mlat=' ~ prevision_destination.latitude|number_format(7, '.', '') ~ '&mlon=' ~ prevision_destination.longitude|number_format(7, '.', '') ~ '#map=16/' ~ prevision_destination.latitude|number_format(7, '.', '') ~ '/' ~ prevision_destination.longitude|number_format(7, '.', '') : '#' %}

    <header class="admin-header">
        <div>
            <h1 class="admin-title">{{ title }}</h1>
            <p class="admin-subtitle">Ce brouillon sert uniquement à mémoriser une destination possible. Il ne crée pas automatiquement une randonnée, une visite ou une destination publique.</p>
        </div>
        <a class="admin-button admin-button--secondary" href="{{ path('admin_prevision_destinations_index') }}">Retour à l’index</a>
    </header>

    <section class="admin-card prevision-form-layout" data-prevision-destination-form>
        {{ form_start(form, { attr: { class: 'admin-form', novalidate: 'novalidate' } }) }}
            {{ form_errors(form) }}
            <input type="hidden" value="" data-prevision-commune-center-latitude>
            <input type="hidden" value="" data-prevision-commune-center-longitude>

            <div class="admin-form-grid">
                <div class="admin-field">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>
                <div class="admin-field">
                    {{ form_label(form.status) }}
                    {{ form_widget(form.status) }}
                    {{ form_errors(form.status) }}
                </div>
                <div class="admin-field">
                    {{ form_label(form.source) }}
                    {{ form_widget(form.source, { attr: { 'data-prevision-source': 'true' } }) }}
                    {{ form_errors(form.source) }}
                </div>
                <div class="admin-field">
                    {{ form_label(form.priority) }}
                    {{ form_widget(form.priority) }}
                    {{ form_errors(form.priority) }}
                </div>
                <div class="admin-field">
                    {{ form_label(form.plannedPeriod) }}
                    {{ form_widget(form.plannedPeriod) }}
                    {{ form_errors(form.plannedPeriod) }}
                </div>
            </div>

            <section class="prevision-form-section" aria-labelledby="prevision-commune-heading">
                <h2 id="prevision-commune-heading">Commune / village</h2>
                <div class="admin-field">
                    <label for="prevision-destination-search">Rechercher une commune française</label>
                    <input id="prevision-destination-search" type="search" autocomplete="off" placeholder="Exemple : Céret, Collioure, Perpignan" data-prevision-search>
                    <p class="admin-muted">La commune sert au classement administratif. Le point sur la carte peut être déplacé pour choisir précisément le lieu à visiter.</p>
                    <p class="admin-muted" data-prevision-search-status>La recherche remplit uniquement ce brouillon de prévision.</p>
                    <div class="prevision-search-results" data-prevision-search-results></div>
                </div>

                <div class="admin-form-grid">
                    <div class="admin-field">
                        {{ form_label(form.commune) }}
                        {{ form_widget(form.commune, { attr: { 'data-prevision-commune': 'true' } }) }}
                        {{ form_errors(form.commune) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.inseeCode) }}
                        {{ form_widget(form.inseeCode, { attr: { 'data-prevision-insee': 'true' } }) }}
                        {{ form_errors(form.inseeCode) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.postalCode) }}
                        {{ form_widget(form.postalCode, { attr: { 'data-prevision-postal': 'true' } }) }}
                        {{ form_errors(form.postalCode) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.department) }}
                        {{ form_widget(form.department, { attr: { 'data-prevision-department': 'true' } }) }}
                        {{ form_errors(form.department) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.region) }}
                        {{ form_widget(form.region, { attr: { 'data-prevision-region': 'true' } }) }}
                        {{ form_errors(form.region) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.country) }}
                        {{ form_widget(form.country, { attr: { 'data-prevision-country': 'true' } }) }}
                        {{ form_errors(form.country) }}
                    </div>
                </div>
            </section>

            <section class="prevision-form-section" aria-labelledby="prevision-point-heading">
                <h2 id="prevision-point-heading">Point précis</h2>
                <p class="admin-muted">Déplacez le marqueur ou cliquez sur la carte pour choisir le point exact.</p>
                <div
                    class="prevision-map"
                    data-prevision-map
                    data-default-latitude="42.6000"
                    data-default-longitude="2.6000"
                    data-default-zoom="9"
                    aria-label="Carte de sélection du point précis"
                ></div>
                <p class="admin-muted prevision-map-status" data-prevision-map-status>{{ has_coordinates ? 'Coordonnées déjà renseignées.' : 'Aucune coordonnée précise n’est renseignée.' }}</p>

                <div class="prevision-point-tools">
                    <div class="admin-row-actions">
                        <button class="admin-button" type="button" data-prevision-validate-point>Valider ce point</button>
                        <button class="admin-button admin-button--secondary" type="button" data-prevision-center-commune>Centrer sur la commune</button>
                        <button class="admin-button admin-button--secondary" type="button" data-prevision-gps>Relever ma position GPS</button>
                    </div>
                    <p class="admin-muted" data-prevision-gps-status>Coordonnées manuelles, carte ou GPS acceptées.</p>
                </div>

                <div class="admin-form-grid">
                    <div class="admin-field">
                        {{ form_label(form.latitude) }}
                        {{ form_widget(form.latitude, { attr: { 'data-prevision-latitude': 'true' } }) }}
                        {{ form_errors(form.latitude) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.longitude) }}
                        {{ form_widget(form.longitude, { attr: { 'data-prevision-longitude': 'true' } }) }}
                        {{ form_errors(form.longitude) }}
                    </div>
                    <div class="admin-field">
                        {{ form_label(form.gpsAccuracy) }}
                        {{ form_widget(form.gpsAccuracy, { attr: { 'data-prevision-accuracy': 'true' } }) }}
                        {{ form_errors(form.gpsAccuracy) }}
                    </div>
                </div>

                <div class="prevision-map-links">
                    <a class="admin-button admin-button--secondary prevision-map-link" href="{{ maps_url }}" target="_blank" rel="noopener noreferrer" data-prevision-maps-link {{ has_coordinates ? '' : 'aria-disabled="true"' }}>Vérifier dans Maps</a>
                    <a class="admin-button admin-button--secondary prevision-map-link" href="{{ osm_url }}" target="_blank" rel="noopener noreferrer" data-prevision-osm-link {{ has_coordinates ? '' : 'aria-disabled="true"' }}>Ouvrir dans OpenStreetMap</a>
                </div>
            </section>

            <div class="admin-field admin-field--full">
                {{ form_label(form.notes) }}
                {{ form_widget(form.notes, { attr: { rows: 6 } }) }}
                {{ form_errors(form.notes) }}
            </div>

            <div class="admin-actions">
                <button class="admin-button" type="submit">{{ submit_label }}</button>
                <a class="admin-button admin-button--secondary" href="{{ path('admin_prevision_destinations_index') }}">Annuler</a>
            </div>
            <p class="prevision-submit-help">Pensez à valider le point sur la carte avant d’enregistrer.</p>
        {{ form_end(form) }}
    </section>
{% endblock %}

{% block javascripts %}
    {% if app.environment != 'test' %}
        {{ vite_entry_script_tags('assets/js/prevision-destination-map.js') }}
    {% endif %}
{% endblock %}
