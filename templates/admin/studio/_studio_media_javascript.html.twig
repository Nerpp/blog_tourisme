<script>
    (() => {
        const videoToggle = document.querySelector('[data-video-toggle]');
        const videoForm = document.querySelector('[data-video-form]');
        const allowedImageTypes = ['image/jpeg', 'image/png', 'image/webp'];
        const panoramaImageTypes = ['image/jpeg', 'image/png', 'image/webp'];
        const imageExtensions = ['jpg', 'jpeg', 'png', 'webp'];

        const formatBytes = (bytes) => {
            if (!Number.isFinite(bytes) || bytes <= 0) {
                return '0 Mo';
            }

            return `${(bytes / 1024 / 1024).toFixed(bytes >= 10 * 1024 * 1024 ? 1 : 2)} Mo`;
        };

        const buildOptions = (options, selected) => Object.entries(options)
            .map(([value, label]) => `<option value="${value}"${value === selected ? ' selected' : ''}>${label}</option>`)
            .join('');

        const readImageDimensions = (file) => new Promise((resolve) => {
            const image = new Image();
            const url = URL.createObjectURL(file);

            image.onload = () => {
                URL.revokeObjectURL(url);
                resolve({ width: image.naturalWidth, height: image.naturalHeight });
            };

            image.onerror = () => {
                URL.revokeObjectURL(url);
                resolve({ width: null, height: null });
            };

            image.src = url;
        });

        const ratioLooksLikePanorama = (width, height) => {
            if (!width || !height) {
                return false;
            }

            const ratio = width / height;

            return ratio >= 1.9 && ratio <= 2.1;
        };

        const detectImageType = (file, width, height) => {
            const filename = (file.name || '').toLowerCase();
            if (filename.includes('180')) {
                return '180';
            }

            if (!width || !height) {
                return 'standard';
            }

            const ratio = width / height;
            if (ratio >= 1.9 && ratio <= 2.1) {
                if (width >= 3000 && panoramaImageTypes.includes(file.type)) {
                    return '360';
                }

                if (width >= 1600 && width < 3000) {
                    return '180';
                }
            }

            if (ratio > 2.2) {
                return 'panorama';
            }

            if (ratio >= 1.65 && ratio <= 2.2) {
                return 'wide_angle';
            }

            return 'standard';
        };

        const extensionForFile = (file) => {
            const parts = (file.name || '').toLowerCase().split('.');

            return parts.length > 1 ? parts.pop() : '';
        };

        const statusLabel = (item) => {
            if (item.status === 'uploading') {
                return `envoi ${item.progress}%`;
            }

            if (item.status === 'processing') {
                return 'traitement';
            }

            if (item.status === 'done') {
                return 'terminé';
            }

            if (item.status === 'error') {
                return 'erreur';
            }

            return 'en attente';
        };

        const sendItem = (form, token, item, onProgress) => new Promise((resolve) => {
            const formData = new FormData();
            formData.append('_token', token);
            formData.append('ajax', '1');
            formData.append('photos[]', item.file, item.file.name);
            formData.append('photoCaptions[]', item.caption);
            formData.append('photoImageTypes[]', item.imageType);
            formData.append('photoAssociations[]', item.association);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', form.dataset.bulkAction || form.action);
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
            xhr.setRequestHeader('Accept', 'application/json');

            xhr.upload.addEventListener('progress', (event) => {
                if (!event.lengthComputable) {
                    return;
                }

                onProgress(Math.min(99, Math.round((event.loaded / event.total) * 100)), 'uploading');
            });

            xhr.addEventListener('load', () => {
                onProgress(100, 'processing');

                let payload = null;
                try {
                    payload = JSON.parse(xhr.responseText || '{}');
                } catch (error) {
                    resolve({ success: false, error: 'Réponse serveur illisible.' });

                    return;
                }

                if (xhr.status >= 200 && xhr.status < 300 && payload.success === true) {
                    resolve(payload);

                    return;
                }

                resolve({ success: false, error: payload.error || 'Upload refusé.' });
            });

            xhr.addEventListener('error', () => resolve({ success: false, error: 'Erreur réseau pendant l’envoi.' }));
            xhr.addEventListener('abort', () => resolve({ success: false, error: 'Envoi annulé.' }));
            xhr.send(formData);
        });

        document.querySelectorAll('[data-photo-upload-form]').forEach((form) => {
            const fileInput = form.querySelector('[data-photo-input]');
            const preview = form.querySelector('[data-photo-preview]');
            const submitButton = form.querySelector('[data-photo-submit]');
            const summary = form.querySelector('[data-photo-upload-summary]');
            const tokenInput = form.querySelector('input[name="_token"]');
            if (!fileInput || !preview || !submitButton || !tokenInput) {
                return;
            }

            const imageTypeOptions = JSON.parse(preview.dataset.imageTypes || '{}');
            const associationOptions = JSON.parse(preview.dataset.associations || '{"gallery":"Galerie générale"}');
            const maxFiles = Number.parseInt(form.dataset.maxFiles || '50', 10);
            const classicMaxFileSize = Number.parseInt(form.dataset.maxFileSize || '31457280', 10);
            const panoramaMaxFileSize = Number.parseInt(form.dataset.panoramaMaxFileSize || '52428800', 10);
            const selectedFiles = [];
            let isUploading = false;

            const imageTypeLabel = (value) => imageTypeOptions[value] || value;

            const syncInputFiles = () => {
                const transfer = new DataTransfer();
                selectedFiles
                    .filter((item) => item.status !== 'error')
                    .forEach((item) => transfer.items.add(item.file));
                fileInput.files = transfer.files;
                submitButton.disabled = isUploading || selectedFiles.filter((item) => item.status === 'pending').length === 0;
            };

            const validateItem = (item) => {
                const extension = extensionForFile(item.file);
                if (!imageExtensions.includes(extension) || !allowedImageTypes.includes(item.file.type)) {
                    item.status = 'error';
                    item.error = 'Format refusé. Utilisez JPG, PNG ou WebP.';
                    item.validationError = true;

                    return;
                }

                const sizeLimit = item.imageType === '360' ? panoramaMaxFileSize : classicMaxFileSize;
                if (item.file.size > sizeLimit) {
                    item.status = 'error';
                    item.error = item.imageType === '360'
                        ? `Image 360° trop lourde : maximum ${formatBytes(panoramaMaxFileSize)}.`
                        : `Photo trop lourde : maximum ${formatBytes(classicMaxFileSize)}.`;
                    item.validationError = true;

                    return;
                }

                if (item.validationError && item.status === 'error') {
                    item.status = 'pending';
                    item.error = null;
                    item.validationError = false;
                }
            };

            const setSummary = (message, type = 'info') => {
                if (!summary) {
                    return;
                }

                summary.hidden = false;
                summary.className = `studio-upload-summary studio-upload-summary--${type}`;
                summary.textContent = message;
            };

            const renderPreview = () => {
                preview.innerHTML = '';
                selectedFiles.forEach((item, index) => {
                    validateItem(item);

                    const card = document.createElement('article');
                    card.className = `studio-preview studio-preview--${item.status}`;

                    const image = document.createElement('img');
                    const url = URL.createObjectURL(item.file);
                    image.src = url;
                    image.alt = item.file.name;
                    image.onload = () => URL.revokeObjectURL(url);
                    card.appendChild(image);

                    const name = document.createElement('span');
                    name.className = 'studio-preview__name';
                    name.textContent = item.file.name;
                    card.appendChild(name);

                    const dimensions = document.createElement('span');
                    dimensions.className = 'studio-preview__meta';
                    const sizeText = formatBytes(item.file.size);
                    if (item.width && item.height) {
                        dimensions.textContent = `${item.width} × ${item.height}px · ${sizeText} · ratio ${(item.width / item.height).toFixed(2)}:1`;
                    } else {
                        dimensions.textContent = `Dimensions en cours de détection · ${sizeText}`;
                    }
                    card.appendChild(dimensions);

                    const status = document.createElement('span');
                    status.className = `studio-preview__status studio-preview__status--${item.status}`;
                    status.textContent = statusLabel(item);
                    card.appendChild(status);

                    const progress = document.createElement('div');
                    progress.className = 'studio-progress';
                    progress.innerHTML = `<span style="width: ${item.progress}%"></span>`;
                    card.appendChild(progress);

                    if (item.error) {
                        const error = document.createElement('p');
                        error.className = 'studio-preview__notice is-warning';
                        error.textContent = item.error;
                        card.appendChild(error);
                    }

                    const captionField = document.createElement('label');
                    captionField.className = 'studio-field';
                    const captionLabel = document.createElement('span');
                    captionLabel.textContent = 'Commentaire photo';
                    const captionInput = document.createElement('textarea');
                    captionInput.name = 'photoCaptions[]';
                    captionInput.rows = 3;
                    captionInput.value = item.caption;
                    captionInput.disabled = isUploading || item.status === 'done';
                    const captionHelp = document.createElement('span');
                    captionHelp.className = 'studio-help';
                    captionHelp.textContent = 'Cette légende pourra être affichée sous la photo.';
                    captionField.append(captionLabel, captionInput, captionHelp);
                    captionInput.addEventListener('input', () => {
                        item.caption = captionInput.value;
                    });
                    card.appendChild(captionField);

                    const row = document.createElement('div');
                    row.className = 'studio-media-row';
                    row.innerHTML = `
                        <label class="studio-field">
                            <span>Type de média</span>
                            <select name="photoImageTypes[]" ${isUploading || item.status === 'done' ? 'disabled' : ''}>${buildOptions(imageTypeOptions, item.imageType)}</select>
                        </label>
                        <label class="studio-field">
                            <span>Associer à</span>
                            <select name="photoAssociations[]" ${isUploading || item.status === 'done' ? 'disabled' : ''}>${buildOptions(associationOptions, item.association)}</select>
                        </label>
                    `;
                    const imageTypeSelect = row.querySelector('select[name="photoImageTypes[]"]');
                    const associationSelect = row.querySelector('select[name="photoAssociations[]"]');

                    imageTypeSelect.addEventListener('change', () => {
                        item.imageType = imageTypeSelect.value;
                        item.imageTypeManuallyChanged = true;
                        validateItem(item);
                        syncInputFiles();
                        renderPreview();
                    });
                    associationSelect.addEventListener('change', () => {
                        item.association = associationSelect.value;
                    });
                    card.appendChild(row);

                    if (item.detectedImageType && !item.imageTypeManuallyChanged) {
                        const detectedNotice = document.createElement('p');
                        detectedNotice.className = 'studio-preview__notice';
                        detectedNotice.textContent = `Type détecté automatiquement : ${imageTypeLabel(item.detectedImageType)}`;
                        card.appendChild(detectedNotice);
                    }

                    if (item.imageType === '360') {
                        const panoramaNotice = document.createElement('p');
                        panoramaNotice.className = 'studio-preview__notice';

                        if (!panoramaImageTypes.includes(item.file.type)) {
                            panoramaNotice.classList.add('is-warning');
                            panoramaNotice.textContent = 'Une image 360° doit être en JPG, PNG ou WebP.';
                        } else if (item.width && item.height && !ratioLooksLikePanorama(item.width, item.height)) {
                            panoramaNotice.classList.add('is-warning');
                            panoramaNotice.textContent = 'Cette image ne ressemble pas à une photo 360° équirectangulaire : la largeur devrait être environ deux fois plus grande que la hauteur.';
                        } else if (item.width && item.height) {
                            panoramaNotice.textContent = 'Image 360° compatible : le panorama sera conservé et affiché dans une vue immersive.';
                        } else {
                            panoramaNotice.textContent = 'Utilisez ce type pour les photos 360° prises avec un drone DJI ou une caméra 360.';
                        }

                        card.appendChild(panoramaNotice);
                    }

                    const removeButton = document.createElement('button');
                    removeButton.className = 'admin-button admin-button--secondary studio-button-danger';
                    removeButton.type = 'button';
                    removeButton.textContent = item.status === 'done' ? 'Masquer' : 'Retirer';
                    removeButton.disabled = isUploading && ['uploading', 'processing'].includes(item.status);
                    removeButton.addEventListener('click', () => {
                        selectedFiles.splice(index, 1);
                        syncInputFiles();
                        renderPreview();
                    });
                    card.appendChild(removeButton);

                    preview.appendChild(card);
                });
            };

            const addFiles = (files) => {
                Array.from(files || []).forEach((file) => {
                    if (selectedFiles.length >= maxFiles) {
                        setSummary(`Sélection limitée à ${maxFiles} fichiers.`, 'warning');

                        return;
                    }

                    const item = {
                        file,
                        caption: '',
                        imageType: 'standard',
                        detectedImageType: null,
                        imageTypeManuallyChanged: false,
                        association: 'gallery',
                        width: null,
                        height: null,
                        status: 'pending',
                        progress: 0,
                        error: null,
                        validationError: false,
                    };

                    validateItem(item);
                    selectedFiles.push(item);
                    readImageDimensions(file).then((dimensions) => {
                        item.width = dimensions.width;
                        item.height = dimensions.height;
                        item.detectedImageType = detectImageType(file, dimensions.width, dimensions.height);
                        if (!item.imageTypeManuallyChanged) {
                            item.imageType = item.detectedImageType;
                        }
                        validateItem(item);
                        syncInputFiles();
                        renderPreview();
                    });
                });
                syncInputFiles();
                renderPreview();
            };

            fileInput.addEventListener('change', () => {
                addFiles(fileInput.files);
            });

            form.addEventListener('dragover', (event) => {
                event.preventDefault();
                form.classList.add('is-drag-over');
            });

            form.addEventListener('dragleave', (event) => {
                if (!form.contains(event.relatedTarget)) {
                    form.classList.remove('is-drag-over');
                }
            });

            form.addEventListener('drop', (event) => {
                event.preventDefault();
                form.classList.remove('is-drag-over');
                addFiles(event.dataTransfer ? event.dataTransfer.files : []);
            });

            form.addEventListener('submit', async (event) => {
                event.preventDefault();
                if (isUploading) {
                    return;
                }

                const pendingItems = selectedFiles.filter((item) => item.status === 'pending');
                if (pendingItems.length === 0) {
                    setSummary('Aucun fichier en attente.', 'warning');

                    return;
                }

                isUploading = true;
                submitButton.disabled = true;
                let sent = 0;
                let failed = selectedFiles.filter((item) => item.status === 'error').length;

                for (const item of pendingItems) {
                    validateItem(item);
                    if (item.status === 'error') {
                        failed += 1;
                        renderPreview();
                        continue;
                    }

                    item.status = 'uploading';
                    item.progress = 0;
                    renderPreview();

                    const payload = await sendItem(form, tokenInput.value, item, (progress, status) => {
                        item.progress = progress;
                        item.status = status;
                        renderPreview();
                    });

                    if (payload.success === true) {
                        item.status = 'done';
                        item.progress = 100;
                        item.mediaId = payload.mediaId || null;
                        sent += 1;
                    } else {
                        item.status = 'error';
                        item.error = payload.error || 'Upload refusé.';
                        item.validationError = false;
                        failed += 1;
                    }

                    setSummary(`${sent} envoyé${sent > 1 ? 's' : ''}, ${failed} échoué${failed > 1 ? 's' : ''}, ${selectedFiles.length} au total.`, failed > 0 ? 'warning' : 'success');
                    renderPreview();
                }

                isUploading = false;
                syncInputFiles();
                setSummary(`${sent} envoyé${sent > 1 ? 's' : ''}, ${failed} échoué${failed > 1 ? 's' : ''}, ${selectedFiles.length} au total.`, failed > 0 ? 'warning' : 'success');
                renderPreview();
            });
        });

        if (videoToggle && videoForm) {
            videoToggle.addEventListener('click', () => {
                videoForm.classList.toggle('studio-hidden');
            });
        }
    })();
</script>
