{% extends 'admin/base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">{{ title }}</h1>
            <p class="admin-subtitle">Formulaire rapide pour un repérage terrain. L’enrichissement média se fait dans le Studio.</p>
        </div>
        <a class="admin-button admin-button--secondary" href="{{ path('admin_places_index') }}">Retour</a>
    </header>

    <section class="admin-card">
        <form class="admin-form" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token(place.id ? 'admin_place_' ~ place.id : 'admin_place_form') }}">
            <section class="admin-card">
                <div class="admin-field">
                    <span class="admin-label">Point GPS du repérage</span>
                    <p class="admin-muted">Ouvrez Google Maps, cherchez le lieu, copiez les coordonnées ou l’URL du point, puis collez-les ici. Le formulaire remplira automatiquement la latitude et la longitude.</p>
                    <p class="admin-muted">Depuis Google Maps, faites un clic droit sur le point puis copiez les coordonnées, ou copiez l’URL du lieu.</p>
                    <div class="admin-row-actions">
                        <a class="admin-button admin-button--secondary" href="https://www.google.com/maps" target="_blank" rel="noopener noreferrer">Ouvrir Google Maps</a>
                        <a class="admin-button admin-button--small admin-button--secondary" href="#" target="_blank" rel="noopener noreferrer" hidden data-place-open-map>Voir le point</a>
                        <a class="admin-button admin-button--small admin-button--secondary" href="#" target="_blank" rel="noopener noreferrer" hidden data-place-directions>Y aller</a>
                    </div>
                </div>
                <div class="admin-field">
                    <label for="gpsPaste">Coller un point GPS ou une URL Google Maps</label>
                    <textarea
                        id="gpsPaste"
                        rows="3"
                        data-gps-paste
                        placeholder="Exemples : 42.769, 2.873 ou https://www.google.com/maps?q=42.769,2.873"
                    ></textarea>
                    <p class="admin-muted" data-place-status>Collez ou saisissez un point GPS.</p>
                </div>
                <div class="admin-form-grid">
                    <div class="admin-field">
                        <label for="place-latitude">Latitude</label>
                        <input id="place-latitude" name="latitude" type="number" step="any" value="{{ place.latitude }}" data-place-latitude>
                    </div>
                    <div class="admin-field">
                        <label for="place-longitude">Longitude</label>
                        <input id="place-longitude" name="longitude" type="number" step="any" value="{{ place.longitude }}" data-place-longitude>
                    </div>
                </div>
            </section>

            <div class="admin-form-grid">
                <div class="admin-field">
                    <label for="place-name">Nom</label>
                    <input id="place-name" name="name" value="{{ place.name }}" required>
                </div>
                <div class="admin-field">
                    <label for="place-destination">Destination</label>
                    <select id="place-destination" name="destination" required>
                        <option value="">Choisir</option>
                        {% for destination in destinations %}
                            <option value="{{ destination.id }}" {% if place.destination and place.destination.id == destination.id %}selected{% endif %}>{{ destination.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="admin-field">
                    <label for="place-category">Catégorie</label>
                    <select id="place-category" name="category">
                        <option value="">Non renseignée</option>
                        {% for category in categories %}
                            <option value="{{ category.id }}" {% if place.category and place.category.id == category.id %}selected{% endif %}>{{ category.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="admin-field">
                    <span class="admin-label">Repérage privé</span>
                    <span class="admin-badge admin-badge--muted">Privé</span>
                    <p class="admin-muted">Cette fiche reste dans le carnet de lieux admin et n’est jamais publiée côté visiteurs.</p>
                </div>
                <div class="admin-field admin-field--full">
                    <label for="place-short-description">Note courte</label>
                    <textarea id="place-short-description" name="shortDescription" rows="3">{{ place.shortDescription }}</textarea>
                </div>
                <div class="admin-field admin-field--full">
                    <label for="place-address">Adresse</label>
                    <input id="place-address" name="address" value="{{ place.address }}">
                </div>
                <div class="admin-field">
                    <label for="place-duration">Temps estimé sur place</label>
                    <input id="place-duration" name="visitDurationMinutes" type="number" min="0" value="{{ place.visitDurationMinutes }}">
                </div>
                <div class="admin-field">
                    <label for="place-difficulty">Accès / difficulté terrain</label>
                    <select id="place-difficulty" name="difficulty">
                        {% for value, label in difficulty_options %}
                            <option value="{{ value }}" {% if place.difficulty and place.difficulty.value == value %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="admin-field">
                    <label for="place-price">Coût éventuel</label>
                    <select id="place-price" name="priceType">
                        {% for value, label in price_options %}
                            <option value="{{ value }}" {% if place.priceType.value == value %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="admin-actions">
                <button class="admin-button" type="submit">{{ submit_label }}</button>
                {% if place.id %}
                    <a class="admin-button admin-button--secondary" href="{{ path('admin_studio_place_edit', { id: place.id }) }}">Ouvrir dans le Studio</a>
                {% endif %}
                <a class="admin-button admin-button--secondary" href="{{ path('admin_places_index') }}">Annuler</a>
            </div>
        </form>
    </section>
{% endblock %}

{% block javascripts %}
    {{ vite_entry_script_tags('assets/js/admin-place-gps.js') }}
{% endblock %}
