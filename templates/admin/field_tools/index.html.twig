{% extends 'admin/base.html.twig' %}

{% block title %}Outils terrain{% endblock %}

{% block body %}
    <header class="admin-header">
        <div>
            <h1 class="admin-title">Outils terrain</h1>
            <p class="admin-subtitle">Accès rapide aux pages smartphone et aux brouillons créés sur le terrain.</p>
        </div>
        <div class="admin-actions">
            <a class="admin-button" href="{{ path('admin_quick_hike_index') }}">Nouvelle rando rapide</a>
            <a class="admin-button admin-button--secondary" href="{{ path('admin_quick_city_visit_index') }}">Nouvelle visite de ville rapide</a>
        </div>
    </header>

    <section class="admin-grid">
        <div class="admin-card">
            <h2>Randonnées rapides</h2>
            {% if latest_hikes is empty %}
                <p class="admin-muted">Aucune randonnée rapide.</p>
            {% else %}
                <ul>
                    {% for hike in latest_hikes %}
                        <li>{{ hike.title }} <span class="admin-muted">({{ hike.status.value }})</span></li>
                    {% endfor %}
                </ul>
            {% endif %}
            <a class="admin-button admin-button--secondary" href="{{ path('admin_field_tools_hikes') }}">Voir les randonnées</a>
        </div>

        <div class="admin-card">
            <h2>Visites de ville rapides</h2>
            {% if latest_city_visits is empty %}
                <p class="admin-muted">Aucune visite de ville rapide.</p>
            {% else %}
                <ul>
                    {% for city_visit in latest_city_visits %}
                        <li>{{ city_visit.title }} <span class="admin-muted">({{ city_visit.status.value }})</span></li>
                    {% endfor %}
                </ul>
            {% endif %}
            <a class="admin-button admin-button--secondary" href="{{ path('admin_field_tools_city_visits') }}">Voir les visites</a>
        </div>
    </section>
{% endblock %}
