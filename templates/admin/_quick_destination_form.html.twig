{% set ui_context = ui_context|default('studio') %}
{% set is_field = ui_context == 'field' %}
{% set container_class = is_field ? 'field-card quick-destination' : 'quick-destination' %}
{% set row_class = is_field ? 'field-row' : 'studio-field' %}
{% set full_row_class = row_class ~ (is_field ? '' : ' studio-field--full') %}
{% set input_class = is_field ? 'field-input' : '' %}
{% set select_class = is_field ? 'field-select' : '' %}
{% set primary_button = is_field ? 'field-button' : 'admin-button' %}
{% set secondary_button = is_field ? 'field-button field-button--secondary' : 'admin-button admin-button--secondary' %}
{% set neutral_button = is_field ? 'field-button field-button--neutral' : 'admin-button admin-button--secondary' %}
{% set destination_quick_create = destination_quick_create|default({}) %}
{% set current_destination_edit = current_destination_edit|default({}) %}
{% set current_destination_update_action = current_destination_update_action|default(null) %}
{% set current_destination_update_token = current_destination_update_token|default(null) %}
{% set destination_type_options = destination_type_options|default({}) %}
{% set current_destination = current_destination|default(null) %}
{% set context_type = destination_quick_create.contextType|default(destination_quick_create.targetType|default('')) %}
{% set context_id = destination_quick_create.contextId|default(destination_quick_create.targetId|default('')) %}
{% set redirect_anchor = redirect_anchor|default(null) %}

<section class="{{ container_class }}" data-quick-destination>
    <div class="quick-destination__header">
        <div>
            <h2 class="quick-destination__title">Destination</h2>
            {% if current_destination %}
                <p class="quick-destination__text">Destination associée : <strong>{{ current_destination.name }}</strong></p>
            {% else %}
                <p class="quick-destination__text">Aucune destination associée</p>
                <p class="quick-destination__text">Si vous êtes hors France ou sans réseau, renseignez la destination manuellement. Vous pourrez compléter les coordonnées plus tard.</p>
            {% endif %}
        </div>
    </div>

    <div class="quick-destination__actions" data-quick-destination-actions>
        {% if current_destination and current_destination_update_action %}
            <button class="{{ primary_button }}" type="button" data-current-destination-toggle>Modifier la destination associée</button>
            <button class="{{ secondary_button }}" type="button" data-quick-destination-toggle>Changer ou créer une autre destination</button>
        {% else %}
            <button class="{{ primary_button }}" type="button" data-quick-destination-toggle>{{ current_destination ? 'Changer ou créer une destination associée' : 'Renseigner manuellement' }}</button>
        {% endif %}
        {% if not current_destination %}
            <button class="{{ neutral_button }}" type="button" data-quick-destination-skip>Enregistrer sans destination pour l’instant</button>
        {% endif %}
    </div>

    {% if current_destination and current_destination_update_action %}
        <form class="quick-destination__form" method="post" action="{{ current_destination_update_action }}" data-current-destination-form hidden>
            <input type="hidden" name="_token" value="{{ current_destination_update_token }}">
            {% if redirect_anchor %}
                <input type="hidden" name="_redirect_anchor" value="{{ redirect_anchor }}">
            {% endif %}

            <div class="quick-destination__grid">
                <div class="{{ row_class }}">
                    <label for="current-destination-country-{{ current_destination.id }}">Pays</label>
                    <input class="{{ input_class }}" id="current-destination-country-{{ current_destination.id }}" name="countryName" value="{{ current_destination_edit.countryName|default('') }}" autocomplete="country-name">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-region-{{ current_destination.id }}">Région / zone</label>
                    <input class="{{ input_class }}" id="current-destination-region-{{ current_destination.id }}" name="regionName" value="{{ current_destination_edit.regionName|default('') }}">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-department-{{ current_destination.id }}">Département / province</label>
                    <input class="{{ input_class }}" id="current-destination-department-{{ current_destination.id }}" name="departmentName" value="{{ current_destination_edit.departmentName|default('') }}">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-city-{{ current_destination.id }}">Ville / lieu</label>
                    <input class="{{ input_class }}" id="current-destination-city-{{ current_destination.id }}" name="cityName" value="{{ current_destination_edit.cityName|default('') }}">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-area-{{ current_destination.id }}">Zone / lieu précis</label>
                    <input class="{{ input_class }}" id="current-destination-area-{{ current_destination.id }}" name="areaName" value="{{ current_destination_edit.areaName|default('') }}">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-type-{{ current_destination.id }}">Type de destination</label>
                    <select class="{{ select_class }}" id="current-destination-type-{{ current_destination.id }}" name="type">
                        {% for value, label in destination_type_options %}
                            <option value="{{ value }}" {% if current_destination_edit.type|default(current_destination.type.value) == value %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-code-{{ current_destination.id }}">Code optionnel</label>
                    <input class="{{ input_class }}" id="current-destination-code-{{ current_destination.id }}" name="code" value="{{ current_destination_edit.code is defined ? current_destination_edit.code : '' }}">
                </div>

                <div class="{{ full_row_class }}">
                    <span class="quick-destination__text">Coordonnées de la destination associée</span>
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-latitude-{{ current_destination.id }}">Latitude optionnelle</label>
                    <input class="{{ input_class }}" id="current-destination-latitude-{{ current_destination.id }}" name="latitude" type="text" inputmode="decimal" value="{{ current_destination_edit.latitude is defined ? current_destination_edit.latitude : '' }}">
                </div>

                <div class="{{ row_class }}">
                    <label for="current-destination-longitude-{{ current_destination.id }}">Longitude optionnelle</label>
                    <input class="{{ input_class }}" id="current-destination-longitude-{{ current_destination.id }}" name="longitude" type="text" inputmode="decimal" value="{{ current_destination_edit.longitude is defined ? current_destination_edit.longitude : '' }}">
                </div>
            </div>

            <div class="quick-destination__actions">
                <button class="{{ primary_button }}" type="submit">Enregistrer la destination</button>
            </div>
        </form>
    {% endif %}

    <form class="quick-destination__form" method="post" action="{{ path('admin_studio_destination_quick_create') }}" data-quick-destination-form hidden>
        <input type="hidden" name="_token" value="{{ csrf_token('studio_destination_quick_create') }}">
        <input type="hidden" name="contextType" value="{{ context_type }}">
        <input type="hidden" name="contextId" value="{{ context_id }}">
        <input type="hidden" name="targetType" value="{{ context_type }}">
        <input type="hidden" name="targetId" value="{{ context_id }}">
        <input type="hidden" name="name" value="{{ destination_quick_create.name|default('') }}">
        <input type="hidden" name="parent" value="{{ destination_quick_create.parent|default('') }}">
        <input type="hidden" name="returnUrl" value="{{ app.request.requestUri }}{{ redirect_anchor ? '#' ~ redirect_anchor : '' }}">
        {% if redirect_anchor %}
            <input type="hidden" name="_redirect_anchor" value="{{ redirect_anchor }}">
        {% endif %}

        {% if current_destination %}
            <h3 class="quick-destination__title">Changer ou créer une autre destination</h3>
        {% endif %}

        <div class="quick-destination__grid">
            <div class="{{ row_class }}">
                <label for="quick-destination-country">Pays</label>
                <input class="{{ input_class }}" id="quick-destination-country" name="countryName" value="{{ destination_quick_create.countryName|default('') }}" autocomplete="country-name">
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-region">Région / zone</label>
                <input class="{{ input_class }}" id="quick-destination-region" name="regionName" value="{{ destination_quick_create.regionName|default('') }}">
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-department">Département / province</label>
                <input class="{{ input_class }}" id="quick-destination-department" name="departmentName" value="{{ destination_quick_create.departmentName|default('') }}">
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-city">Ville / lieu</label>
                <input class="{{ input_class }}" id="quick-destination-city" name="cityName" value="{{ destination_quick_create.cityName|default('') }}">
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-type">Type de destination</label>
                <select class="{{ select_class }}" id="quick-destination-type" name="type">
                    {% for value, label in destination_type_options %}
                        <option value="{{ value }}" {% if destination_quick_create.type|default('area') == value %}selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-code">Code optionnel</label>
                <input class="{{ input_class }}" id="quick-destination-code" name="code" value="{{ destination_quick_create.code|default('') }}">
            </div>

            <div class="{{ full_row_class }}">
                <span class="quick-destination__text">Coordonnées optionnelles</span>
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-latitude">Latitude optionnelle</label>
                <input class="{{ input_class }}" id="quick-destination-latitude" name="latitude" type="number" step="any" value="{{ destination_quick_create.latitude|default('') }}" data-quick-destination-latitude>
            </div>

            <div class="{{ row_class }}">
                <label for="quick-destination-longitude">Longitude optionnelle</label>
                <input class="{{ input_class }}" id="quick-destination-longitude" name="longitude" type="number" step="any" value="{{ destination_quick_create.longitude|default('') }}" data-quick-destination-longitude>
            </div>
        </div>

        <p class="quick-destination__status" data-quick-destination-status aria-live="polite"></p>
        <div class="quick-destination__actions">
            <button class="{{ neutral_button }}" type="button" data-quick-destination-gps>Utiliser ma position actuelle</button>
            <button class="{{ secondary_button }}" type="submit">{{ context_type and context_id ? 'Créer et associer' : 'Créer la destination' }}</button>
        </div>
    </form>

    <p class="quick-destination__status" data-quick-destination-skip-status hidden>Destination à compléter plus tard.</p>
</section>

<script>
    (() => {
        document.querySelectorAll('[data-quick-destination]').forEach((container) => {
            const toggle = container.querySelector('[data-quick-destination-toggle]');
            const currentToggle = container.querySelector('[data-current-destination-toggle]');
            const skipButton = container.querySelector('[data-quick-destination-skip]');
            const actions = container.querySelector('[data-quick-destination-actions]');
            const gpsButton = container.querySelector('[data-quick-destination-gps]');
            const form = container.querySelector('[data-quick-destination-form]');
            const currentForm = container.querySelector('[data-current-destination-form]');
            const latitude = container.querySelector('[data-quick-destination-latitude]');
            const longitude = container.querySelector('[data-quick-destination-longitude]');
            const status = container.querySelector('[data-quick-destination-status]');
            const skipStatus = container.querySelector('[data-quick-destination-skip-status]');

            if (toggle && form) {
                toggle.addEventListener('click', () => {
                    form.hidden = false;
                    if (currentForm) {
                        currentForm.hidden = true;
                    }
                    toggle.hidden = true;
                    if (skipStatus) {
                        skipStatus.hidden = true;
                    }
                });
            }

            if (currentToggle && currentForm) {
                currentToggle.addEventListener('click', () => {
                    currentForm.hidden = false;
                    if (form) {
                        form.hidden = true;
                    }
                    currentToggle.hidden = true;
                    if (skipStatus) {
                        skipStatus.hidden = true;
                    }
                });
            }

            if (skipButton) {
                skipButton.addEventListener('click', () => {
                    if (form) {
                        form.hidden = true;
                    }

                    if (actions) {
                        actions.hidden = true;
                    }

                    if (skipStatus) {
                        skipStatus.hidden = false;
                    }
                });
            }

            if (gpsButton && latitude && longitude) {
                gpsButton.addEventListener('click', () => {
                    if (!navigator.geolocation) {
                        if (status) {
                            status.textContent = 'La géolocalisation n’est pas disponible sur cet appareil.';
                        }

                        return;
                    }

                    gpsButton.disabled = true;
                    if (status) {
                        status.textContent = 'Récupération de la position GPS...';
                    }

                    navigator.geolocation.getCurrentPosition(
                        (position) => {
                            latitude.value = position.coords.latitude.toFixed(6);
                            longitude.value = position.coords.longitude.toFixed(6);
                            gpsButton.disabled = false;
                            if (status) {
                                status.textContent = 'Position récupérée.';
                            }
                        },
                        () => {
                            gpsButton.disabled = false;
                            if (status) {
                                status.textContent = 'Impossible de récupérer la position GPS.';
                            }
                        },
                        {
                            enableHighAccuracy: true,
                            timeout: 15000,
                            maximumAge: 0,
                        }
                    );
                });
            }
        });
    })();
</script>
