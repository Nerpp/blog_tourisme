{% extends 'base.html.twig' %}

{% block title %}{{ place.seoTitle ?: place.name }} - Blog Tourisme{% endblock %}
{% block meta_description %}{{ place.seoDescription ?: place.shortDescription ?: 'Lieu touristique a decouvrir sur Blog Tourisme.' }}{% endblock %}
{% block open_graph_title %}{{ place.seoTitle ?: place.name }}{% endblock %}
{% block open_graph_description %}{{ place.seoDescription ?: place.shortDescription ?: 'Lieu touristique a decouvrir sur Blog Tourisme.' }}{% endblock %}

{% block body %}
    <main class="page-shell article-layout">
        <article class="article-main">
            <header class="page-header">
                <p class="eyebrow">
                    {% if place.category %}{{ place.category.name }}{% else %}Lieu{% endif %}
                    {% if place.destination %} - {{ place.destination.name }}{% endif %}
                </p>
                <h1>{{ place.name }}</h1>
                {% if place.shortDescription %}
                    <p>{{ place.shortDescription }}</p>
                {% endif %}
            </header>

            <div class="featured-media">
                {% include 'partials/_cover_media.html.twig' with {
                    featured_media: place.featuredImage,
                    media_links: place.mediaLinks
                } only %}
            </div>

            {% if place.description %}
                <div class="prose">{{ place.description|nl2br }}</div>
            {% endif %}

            {% set special_media_links = place.mediaLinks|filter(link => link.mediaAsset.mediaType.value == 'video' or not link.mediaAsset.imageType or link.mediaAsset.imageType.value != 'standard') %}
            {% if special_media_links|length > 0 %}
                <section class="section-block">
                    <h2>Photos et vidéos</h2>
                    {% include 'partials/_media_gallery.html.twig' with { media_links: special_media_links } only %}
                </section>
            {% endif %}
        </article>

        <aside class="side-panel">
            <section>
                <h2>Infos pratiques</h2>
                <dl class="facts-list">
                    {% if place.destination %}
                        <div><dt>Destination</dt><dd><a href="{{ path('app_destination_show', { slug: place.destination.slug }) }}">{{ place.destination.name }}</a></dd></div>
                    {% endif %}
                    {% if place.category %}<div><dt>Categorie</dt><dd>{{ place.category.name }}</dd></div>{% endif %}
                    {% if place.address %}<div><dt>Adresse</dt><dd>{{ place.address }}</dd></div>{% endif %}
                    {% if place.visitDurationMinutes %}<div><dt>Duree</dt><dd>{{ place.visitDurationMinutes }} min</dd></div>{% endif %}
                    {% if place.difficulty %}<div><dt>Difficulte</dt><dd>{{ place.difficulty.value }}</dd></div>{% endif %}
                    {% if place.priceType %}<div><dt>Prix</dt><dd>{{ place.priceType.value }}</dd></div>{% endif %}
                    {% if place.latitude is not null and place.longitude is not null %}
                        <div>
                            <dt>Coordonnees</dt>
                            <dd>
                                {{ place.latitude }}, {{ place.longitude }}
                                {% include 'partials/_google_maps_link.html.twig' with { place: place } only %}
                            </dd>
                        </div>
                    {% elseif place.name and place.destination %}
                        <div>
                            <dt>Carte</dt>
                            <dd>
                                {% include 'partials/_google_maps_link.html.twig' with { place: place } only %}
                            </dd>
                        </div>
                    {% endif %}
                </dl>
            </section>

            {% if place.tagLinks|length > 0 %}
                <section>
                    <h2>Tags</h2>
                    <div class="badges">
                        {% for tagLink in place.tagLinks %}
                            <span class="badge">{{ tagLink.tag.name }}</span>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if place.articleLinks|length > 0 %}
                <section>
                    <h2>Articles lies</h2>
                    <div class="stacked-links">
                        {% for articleLink in place.articleLinks %}
                            {% if articleLink.article.status.value == 'published' %}
                                <a href="{{ path('app_article_show', { slug: articleLink.article.slug }) }}">{{ articleLink.article.title }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </aside>

        <div class="full-span">
            {% include 'partials/_comments.html.twig' with { comments: comments } %}
            {% include 'partials/_comment_form.html.twig' with { comment_form: comment_form } %}
        </div>
    </main>
{% endblock %}
