{% extends 'base.html.twig' %}

{% block title %}Email envoyé - Blog Tourisme{% endblock %}

{% block body %}
    <main class="login-page">
        <section class="login-shell" aria-labelledby="reset-check-title">
            <aside class="login-hero" aria-label="Email de réinitialisation">
                <div class="login-hero__content">
                    <a class="login-brand" href="{{ path('app_home') }}">Blog Tourisme</a>
                    <p class="login-eyebrow">Lien temporaire</p>
                    <h1 id="reset-check-title">Vérifiez votre messagerie</h1>
                    <p class="login-hero__text">
                        Le lien de réinitialisation est temporaire et expire automatiquement.
                    </p>
                </div>
            </aside>

            <section class="login-panel" aria-label="Confirmation d’envoi">
                <div class="login-card">
                    <div class="login-card__header">
                        <p class="login-card__kicker">Demande prise en compte</p>
                        <h2>Email envoyé</h2>
                        <p>{{ generic_message }}</p>
                        <p>Le lien reste valide pendant {{ reset_token_lifetime // 60 }} minute{{ reset_token_lifetime // 60 > 1 ? 's' : '' }}.</p>
                    </div>

                    <div class="login-links" aria-label="Liens utiles">
                        <a href="{{ path('app_login') }}">Retour à la connexion</a>
                        <a href="{{ path('app_forgot_password_request') }}">Renvoyer une demande</a>
                    </div>
                </div>
            </section>
        </section>
    </main>
{% endblock %}
