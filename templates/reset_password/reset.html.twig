{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Blog Tourisme{% endblock %}

{% block body %}
    <main class="login-page auth-reset-page auth-reset-page--new-password">
        <section class="login-shell auth-reset-shell" aria-labelledby="reset-password-title">
            <aside class="login-hero auth-reset-hero" aria-label="Nouveau mot de passe">
                <div class="login-hero__content auth-reset-hero__content">
                    <a class="login-brand" href="{{ path('app_home') }}">Blog Tourisme</a>
                    <p class="login-eyebrow">Sécurité du compte</p>
                    <h1 id="reset-password-title" class="auth-reset-title">Créer un nouveau mot de passe</h1>
                    <p class="login-hero__text auth-reset-subtitle">
                        Choisissez un mot de passe solide pour protéger votre compte.
                    </p>

                    <div class="login-badges auth-reset-badges" aria-label="Conseils de protection">
                        <span>Phrase longue</span>
                        <span>Compte protégé</span>
                        <span>Connexion apaisée</span>
                    </div>
                </div>

                <div class="auth-reset-visual auth-reset-visual--password" aria-hidden="true">
                    <span class="auth-reset-visual__sun"></span>
                    <span class="auth-reset-visual__ridge auth-reset-visual__ridge--back"></span>
                    <span class="auth-reset-visual__ridge auth-reset-visual__ridge--front"></span>
                    <span class="auth-reset-visual__shield"></span>
                </div>
            </aside>

            <section class="login-panel" aria-label="Formulaire de nouveau mot de passe">
                <div class="login-card auth-reset-card">
                    <div class="login-card__header">
                        <p class="login-card__kicker">Réinitialisation</p>
                        <h2>Créer un nouveau mot de passe</h2>
                        <p>Choisissez une phrase longue et personnelle, facile à retenir mais difficile à deviner.</p>
                    </div>

                    {{ form_start(reset_form, { attr: { class: 'login-form', novalidate: 'novalidate' } }) }}
                        {{ form_errors(reset_form) }}

                        <div class="login-field">
                            {{ form_label(reset_form.plainPassword.first) }}
                            {{ form_widget(reset_form.plainPassword.first, { attr: { class: 'login-input' } }) }}
                            {{ form_errors(reset_form.plainPassword.first) }}
                        </div>

                        <div class="login-field">
                            {{ form_label(reset_form.plainPassword.second) }}
                            {{ form_widget(reset_form.plainPassword.second, { attr: { class: 'login-input' } }) }}
                            {{ form_errors(reset_form.plainPassword.second) }}
                            {{ form_errors(reset_form.plainPassword) }}
                        </div>

                        <div class="password-guidelines" aria-label="Conseils pour créer un mot de passe solide">
                            <p>Repères pour un mot de passe solide</p>
                            <ul>
                                <li>12 caractères minimum.</li>
                                <li>Évitez les mots de passe courants.</li>
                                <li>Utilisez une phrase facile à retenir.</li>
                                <li>Mélangez lettres, chiffres et symboles si possible.</li>
                            </ul>
                        </div>

                        <button class="login-button" type="submit">Mettre à jour mon mot de passe</button>
                    {{ form_end(reset_form) }}

                    <div class="login-links auth-reset-actions" aria-label="Liens utiles">
                        <a href="{{ path('app_login') }}">Retour à la connexion</a>
                    </div>
                </div>
            </section>
        </section>
    </main>
{% endblock %}
