<!doctype html>
<html lang="fr">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>
			{% block title %}Blog Tourisme
			{% endblock %}
		</title>
		<meta name="description" content="{% block meta_description %}Articles, itineraires et conseils pour decouvrir les plus belles destinations touristiques.{% endblock %}">
		{% block canonical %}<link rel="canonical" href="{{ app.request.uri }}">
		{% endblock %}
		<meta property="og:title" content="{% block open_graph_title %}{{ block('title') }}{% endblock %}">
		<meta property="og:description" content="{% block open_graph_description %}{{ block('meta_description') }}{% endblock %}"> {% block open_graph_image %}{% endblock %}
		{% block preloads %}{% endblock %}
		{% block stylesheets %}
			{{ vite_entry_link_tags('app') }}
		{% endblock %}
	</head>
	<body>
		{% block site_header %}
			{% include 'partials/nav/_navbar.html.twig' %}
		{% endblock %}

		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="flash flash-{{ label }}">{{ message }}</div>
			{% endfor %}
		{% endfor %}

		{% if app.user and app.user.verified is defined and not app.user.verified %}
			<div class="flash flash-warning">
				Votre email n’est pas encore confirmé. Certaines actions comme commenter seront limitées.
				<a href="{{ path('app_verify_email_resend') }}">Renvoyer l’email de confirmation</a>
			</div>
		{% endif %}

		{% block body %}{% endblock %}

		{% block site_footer %}
            {% include 'partials/footer/_footer.html.twig' %}
        {% endblock %}

		{% block javascripts %}
			{{ vite_entry_script_tags('app') }}
		{% endblock %}
	</body>
</html>
