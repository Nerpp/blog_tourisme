{% extends 'base.html.twig' %}

{% block title %}{{ article.seoTitle ?: article.title }} - Blog Tourisme{% endblock %}
{% block meta_description %}{{ article.seoDescription ?: article.excerpt ?: 'Article tourisme publie sur Blog Tourisme.' }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ article.canonicalUrl ?: app.request.uri }}">{% endblock %}
{% block open_graph_title %}{{ article.seoTitle ?: article.title }}{% endblock %}
{% block open_graph_description %}{{ article.seoDescription ?: article.excerpt ?: 'Article tourisme publie sur Blog Tourisme.' }}{% endblock %}

{% block body %}
    <main class="page-shell article-layout">
        <article class="article-main">
            <header class="page-header">
                <p class="eyebrow">
                    {% if article.category %}{{ article.category.name }}{% else %}Article{% endif %}
                    {% if article.publishedAt %} - {{ article.publishedAt|date('d/m/Y') }}{% endif %}
                </p>
                <h1>{{ article.title }}</h1>
                {% if article.excerpt %}
                    <p>{{ article.excerpt }}</p>
                {% endif %}
            </header>

            <div class="featured-media">
                {% include 'partials/_cover_media.html.twig' with {
                    featured_media: article.featuredImage,
                    media_links: article.mediaLinks
                } only %}
            </div>

            <div class="prose">{{ article.content|nl2br }}</div>

            {% set special_media_links = article.mediaLinks|filter(link => link.mediaAsset.mediaType.value == 'video' or not link.mediaAsset.imageType or link.mediaAsset.imageType.value != 'standard') %}
            {% if special_media_links|length > 0 %}
                <section class="section-block">
                    <h2>Photos et vidéos</h2>
                    {% include 'partials/_media_gallery.html.twig' with { media_links: special_media_links } only %}
                </section>
            {% endif %}
        </article>

        <aside class="side-panel">
            {% if article.tagLinks|length > 0 %}
                <section>
                    <h2>Tags</h2>
                    <div class="badges">
                        {% for tagLink in article.tagLinks %}
                            <span class="badge">{{ tagLink.tag.name }}</span>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if article.destinationLinks|length > 0 %}
                <section>
                    <h2>Destinations liees</h2>
                    <div class="stacked-links">
                        {% for destinationLink in article.destinationLinks %}
                            <a href="{{ path('app_destination_show', { slug: destinationLink.destination.slug }) }}">{{ destinationLink.destination.name }}</a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if article.placeLinks|length > 0 %}
                <section>
                    <h2>Lieux cites</h2>
                    <div class="stacked-links">
                        {% for placeLink in article.placeLinks %}
                            <a href="{{ path('app_place_show', { slug: placeLink.place.slug }) }}">{{ placeLink.place.name }}</a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </aside>

        <div class="full-span">
            {% include 'partials/_comments.html.twig' with { comments: comments } %}
            {% include 'partials/_comment_form.html.twig' with { comment_form: comment_form } %}
        </div>
    </main>
{% endblock %}
