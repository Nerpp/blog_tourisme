{% extends 'base.html.twig' %}

{% block title %}{{ article.seoTitle ?: article.title }} - Blog Tourisme{% endblock %}
{% block meta_description %}{{ article.seoDescription ?: article.excerpt ?: 'Article tourisme publie sur Blog Tourisme.' }}{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ article.canonicalUrl ?: app.request.uri }}">{% endblock %}
{% block open_graph_title %}{{ article.seoTitle ?: article.title }}{% endblock %}
{% block open_graph_description %}{{ article.seoDescription ?: article.excerpt ?: 'Article tourisme publie sur Blog Tourisme.' }}{% endblock %}

{% block body %}
    <main class="page-shell article-layout">
        <article class="article-main">
            <header class="page-header">
                <p class="eyebrow">
                    {% if article.category %}{{ article.category.name }}{% else %}Article{% endif %}
                    {% if article.publishedAt %} - {{ article.publishedAt|date('d/m/Y') }}{% endif %}
                </p>
                <h1>{{ article.title }}</h1>
                {% if is_granted('EDIT', article) %}
                    <div class="show-admin-actions">
                        <a href="{{ path('admin_articles_edit', { id: article.id }) }}" class="show-admin-edit-link">Modifier</a>
                    </div>
                {% endif %}
                {% if article.excerpt %}
                    <p>{{ article.excerpt }}</p>
                {% endif %}
            </header>

            <div class="featured-media">
                {% include 'partials/_cover_media.html.twig' with {
                    featured_media: article.featuredImage,
                    media_links: article.mediaLinks,
                    media_context: article
                } only %}
            </div>

            <div class="prose article-content">
                {{ article_content_html(article) }}
            </div>

            {% set gallery_media_links = article.mediaLinks|filter(link => link.role.value == 'gallery') %}
            {% if gallery_media_links|length > 0 %}
                <section class="section-block article-gallery-section">
                    <h2>Galerie</h2>
                    {% include 'partials/_media_gallery.html.twig' with { media_links: gallery_media_links } only %}
                </section>
            {% endif %}
        </article>

        <aside class="side-panel">
            {% if article.tagLinks|length > 0 %}
                <section>
                    <h2>Tags</h2>
                    <div class="badges">
                        {% for tagLink in article.tagLinks %}
                            <span class="badge">{{ tagLink.tag.name }}</span>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if article.destinationLinks|length > 0 %}
                <section>
                    <h2>Destinations liees</h2>
                    <div class="stacked-links">
                        {% for destinationLink in article.destinationLinks %}
                            <a href="{{ path('app_destination_show', { slug: destinationLink.destination.slug }) }}">{{ destinationLink.destination.name }}</a>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if article.hikeLinks|length > 0 or article.cityVisitLinks|length > 0 or article.placeLinks|length > 0 %}
                <section>
                    <h2>À découvrir pendant la balade</h2>
                    <div class="stacked-links">
                        {% for hikeLink in article.hikeLinks %}
                            {% if hikeLink.hikeDraft.status.value in ['finished', 'converted'] %}
                                <a href="{{ path('app_hike_show', { slug: hikeLink.hikeDraft.slug }) }}">{{ hikeLink.hikeDraft.title }}</a>
                            {% endif %}
                        {% endfor %}

                        {% for cityVisitLink in article.cityVisitLinks %}
                            {% if cityVisitLink.cityVisitDraft.status.value in ['finished', 'converted'] %}
                                <a href="{{ path('app_city_visit_show', { slug: cityVisitLink.cityVisitDraft.slug }) }}">{{ cityVisitLink.cityVisitDraft.title }}</a>
                            {% endif %}
                        {% endfor %}

                        {% for placeLink in article.placeLinks %}
                            {% if placeLink.place.status.value == 'published' %}
                                <a href="{{ path('app_place_show', { slug: placeLink.place.slug }) }}">{{ placeLink.place.name }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>
                </section>
            {% endif %}
        </aside>

        <div class="full-span">
            {% include 'partials/_comments.html.twig' with { comments: comments } %}
            {% include 'partials/_comment_form.html.twig' with { comment_form: comment_form } %}
        </div>
    </main>
{% endblock %}
