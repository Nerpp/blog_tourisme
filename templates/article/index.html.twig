{% extends 'base.html.twig' %}

{% block title %}Articles tourisme - Blog Tourisme{% endblock %}
{% block meta_description %}Tous les articles publies : itineraires, conseils voyage et idees de decouverte pour preparer vos visites.{% endblock %}

{% block body %}
    <main class="page-shell">
        <header class="page-header">
            <p class="eyebrow">Articles</p>
            <h1>Itineraires et conseils voyage</h1>
            <p>Retrouvez les derniers contenus publies, leurs destinations associees et les lieux cites dans chaque article.</p>
        </header>

        <div class="card-grid">
            {% for article in articles %}
                {% include 'partials/_article_card.html.twig' with { article: article } only %}
            {% else %}
                <p>Aucun article publie pour le moment.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
