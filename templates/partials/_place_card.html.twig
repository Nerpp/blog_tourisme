<article class="content-card">
    {% set title_level = heading_level|default(3) %}

    {% include 'partials/_cover_media.html.twig' with {
        featured_media: place.featuredImage,
        media_links: place.mediaLinks,
        media_context: place
    } only %}
    <div class="card-body">
        <p class="card-meta">
            {% if place.destination %}<span>{{ place.destination.name }}</span>{% endif %}
            {% if place.category %}<span>{{ place.category.name }}</span>{% endif %}
        </p>
        <h{{ title_level }}><a href="{{ path('app_place_show', { slug: place.slug }) }}">{{ place.name }}</a></h{{ title_level }}>
        {% if place.shortDescription %}
            <p>{{ place.shortDescription }}</p>
        {% endif %}
        <a class="text-link" href="{{ path('app_place_show', { slug: place.slug }) }}">Voir la fiche</a>
    </div>
</article>
