{% set featured_media = featured_media|default(null) %}
{% set media_links = media_links|default([]) %}
{% set media_context = media_context|default(null) %}
{% set cover_image_size = cover_image_size|default('thumb') %}
{% set cover_sizes = cover_sizes|default('(min-width: 900px) 360px, 100vw') %}
{% set cover_display_profile = display_profile|default(null) %}
{% set cover_media = null %}
{% set cover_is_special = false %}

{% set cover_standard_media_links = media_links|filter(link => link.role.value == 'cover' and link.mediaAsset.mediaType.value == 'image' and link.mediaAsset.imageType and link.mediaAsset.imageType.value == 'standard') %}
{% set cover_preview_media_links = media_links|filter(link => link.role.value == 'cover' and link.mediaAsset.mediaType.value == 'image' and link.mediaAsset.thumbnailPath) %}

{% if cover_standard_media_links|length > 0 %}
    {% set cover_media = (cover_standard_media_links|first).mediaAsset %}
{% elseif cover_preview_media_links|length > 0 %}
    {% set cover_media = (cover_preview_media_links|first).mediaAsset %}
    {% set cover_is_special = cover_media.imageType and cover_media.imageType.value != 'standard' %}
{% elseif featured_media and featured_media.mediaType.value == 'image' and featured_media.imageType and featured_media.imageType.value == 'standard' %}
    {% set cover_media = featured_media %}
{% elseif featured_media and featured_media.mediaType.value == 'image' and featured_media.thumbnailPath %}
    {% set cover_media = featured_media %}
    {% set cover_is_special = featured_media.imageType and featured_media.imageType.value != 'standard' %}
{% else %}
    {% set standard_media_links = media_links|filter(link => link.mediaAsset.mediaType.value == 'image' and link.mediaAsset.imageType and link.mediaAsset.imageType.value == 'standard') %}
    {% if standard_media_links|length > 0 %}
        {% set cover_media = (standard_media_links|first).mediaAsset %}
    {% else %}
        {% set preview_media_links = media_links|filter(link => link.mediaAsset.mediaType.value == 'image' and link.mediaAsset.thumbnailPath) %}
        {% if preview_media_links|length > 0 %}
            {% set cover_media = (preview_media_links|first).mediaAsset %}
            {% set cover_is_special = cover_media.imageType and cover_media.imageType.value != 'standard' %}
        {% endif %}
    {% endif %}
{% endif %}

{% set cover_path = cover_media ? media_image_url(cover_media, 'thumb') : null %}
{% if cover_media
    and cover_media.imageType
    and cover_media.imageType.value != 'standard'
    and not cover_media.thumbnailPath
    and not cover_media.variants
%}
    {% set cover_path = null %}
{% endif %}
{% set is_demo_file = cover_path and cover_path starts with '/uploads/demo/' %}

<div class="cover-media">
    {% if cover_media and cover_path and not is_demo_file %}
        {% set responsive_image_options = {
            media: cover_media,
            alt: media_public_alt(cover_media, media_context, 'Image de couverture'),
            image_size: cover_image_size,
            sizes: cover_sizes
        } %}
        {% if cover_display_profile and cover_media.imageType and cover_media.imageType.value == 'standard' %}
            {% set responsive_image_options = responsive_image_options|merge({ display_profile: cover_display_profile }) %}
        {% endif %}
        {% include 'public_detail/_responsive_image.html.twig' with responsive_image_options only %}
        {% if cover_is_special and cover_media.imageType %}
            <span class="cover-media__badge">{{ cover_media.imageType.value == '360' ? '360°' : (cover_media.imageType.value == '180' ? '180°' : 'Panorama') }}</span>
        {% endif %}
    {% else %}
        <div class="cover-placeholder" role="img" aria-label="{{ cover_media ? media_public_alt(cover_media, media_context, 'Image de couverture') : 'Image de couverture non disponible' }}">
            <span>Image de couverture</span>
        </div>
    {% endif %}
</div>
