<ul class="destination-tree">
    {% for destination in destinations %}
        {% set counts = destination_counts[destination.id]|default({
            places: 0,
            articles: 0,
            hikes: 0,
            city_visits: 0,
            total: 0
        }) %}
        <li>
            <a href="{{ path('app_destination_show', { slug: destination.slug }) }}">{{ destination.name }}</a>
            <span>{{ destination.type.value }}</span>
            <small>{{ counts.places }} lieu{{ counts.places != 1 ? 'x' : '' }}</small>
            <small>{{ counts.articles }} article{{ counts.articles != 1 ? 's' : '' }}</small>
            <small>{{ counts.hikes }} randonnée{{ counts.hikes != 1 ? 's' : '' }}</small>
            <small>{{ counts.city_visits }} visite{{ counts.city_visits != 1 ? 's' : '' }}</small>
            {% if destination.children|length > 0 %}
                {% include 'partials/_destination_tree.html.twig' with {
                    destinations: destination.children,
                    destination_counts: destination_counts
                } only %}
            {% endif %}
        </li>
    {% endfor %}
</ul>
