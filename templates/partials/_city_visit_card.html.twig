<article class="content-card destination-content-card">
    <a class="destination-content-card__media" href="{{ path('app_city_visit_show', { slug: city_visit.slug }) }}" aria-label="Voir la visite de ville {{ city_visit.title }}">
        {% include 'partials/_cover_media.html.twig' with {
            featured_media: null,
            media_links: city_visit.mediaLinks,
            media_context: city_visit
        } only %}
    </a>
    <div class="card-body">
        <p class="card-meta">
            <span>Visite de ville</span>
            {% if city_visit.destination %}<span>{{ city_visit.destination.name }}</span>{% endif %}
            {% if city_visit.finishedAt %}<span>{{ city_visit.finishedAt|date('d/m/Y') }}</span>{% endif %}
        </p>
        <h3><a href="{{ path('app_city_visit_show', { slug: city_visit.slug }) }}">{{ city_visit.title }}</a></h3>
        {% if city_visit.notes %}
            <p>{{ city_visit.notes|striptags|slice(0, 150) }}{{ city_visit.notes|striptags|length > 150 ? '...' : '' }}</p>
        {% endif %}
        <a class="text-link" href="{{ path('app_city_visit_show', { slug: city_visit.slug }) }}">Voir la visite</a>
    </div>
</article>
