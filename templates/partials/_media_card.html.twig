{% set type = media.mediaType.value %}
{% set image_type = media.imageType ? media.imageType.value : null %}
{% set badge = type == 'video'
    ? 'Vidéo'
    : ({
        'standard': 'Standard',
        '360': '360°',
        '180': '180°',
        'panorama': 'Panorama',
        'wide_angle': 'Grand angle'
    }[image_type]|default('Image'))
%}
{% set is_demo_file = media.filePath and media.filePath starts with '/uploads/demo/' %}
{% set image_path = media_image_url(media, 'thumb') %}
{% if image_type != 'standard' and not media.thumbnailPath and not media.variants %}
    {% set image_path = null %}
{% endif %}
{% set is_demo_image = image_path and image_path starts with '/uploads/demo/' %}

<article class="media-card" data-media-type="{{ type }}" {% if image_type %}data-image-type="{{ image_type }}"{% endif %}>
    <div class="media-visual">
        <span class="badge media-badge">{{ badge }}</span>

        {% if type == 'image' %}
            {% if image_path and not is_demo_image %}
                {% include 'public_detail/_responsive_image.html.twig' with {
                    media: media,
                    alt: media.altText ?: media.title ?: 'Media touristique',
                    image_size: 'thumb',
                    sizes: '(min-width: 900px) 280px, 100vw'
                } only %}
            {% else %}
                <div class="media-placeholder" role="img" aria-label="{{ media.altText ?: media.title ?: 'Image de demonstration' }}">
                    <span>{{ badge }}</span>
                </div>
            {% endif %}
        {% elseif type == 'video' %}
            {% set poster_url = media_poster_url(media, 'thumb') %}

            {% if poster_url and not (poster_url starts with '/uploads/demo/') %}
                <img src="{{ poster_url }}" alt="{{ media.altText ?: media.title ?: 'Video touristique' }}" loading="lazy" decoding="async">
            {% else %}
                <div class="media-placeholder media-placeholder-video" role="img" aria-label="{{ media.altText ?: media.title ?: 'Vidéo de demonstration' }}">
                    <span>Vidéo</span>
                </div>
            {% endif %}
        {% endif %}
    </div>

    <div class="media-body">
        {% if media.title %}
            <h3>{{ media.title }}</h3>
        {% endif %}
        {% if media.caption %}
            <p>{{ media.caption }}</p>
        {% endif %}
        {% if type == 'video' and media.externalUrl %}
            <a href="{{ media.externalUrl }}" rel="noopener noreferrer" target="_blank">Voir la video</a>
        {% elseif media.filePath %}
            <small>{{ is_demo_file ? 'Fichier de demonstration non present sur le disque' : media.filePath }}</small>
        {% endif %}
    </div>
</article>
