<article class="content-card destination-content-card">
    <a class="destination-content-card__media" href="{{ path('app_hike_show', { slug: hike.slug }) }}" aria-label="Voir la randonnée {{ hike.title }}">
        {% include 'partials/_cover_media.html.twig' with {
            featured_media: null,
            media_links: hike.mediaLinks
        } only %}
    </a>
    <div class="card-body">
        <p class="card-meta">
            <span>Randonnée</span>
            {% if hike.destination %}<span>{{ hike.destination.name }}</span>{% endif %}
            {% if hike.finishedAt %}<span>{{ hike.finishedAt|date('d/m/Y') }}</span>{% endif %}
        </p>
        <h3><a href="{{ path('app_hike_show', { slug: hike.slug }) }}">{{ hike.title }}</a></h3>
        {% if hike.notes %}
            <p>{{ hike.notes|striptags|slice(0, 150) }}{{ hike.notes|striptags|length > 150 ? '...' : '' }}</p>
        {% endif %}
        <a class="text-link" href="{{ path('app_hike_show', { slug: hike.slug }) }}">Voir la randonnée</a>
    </div>
</article>
