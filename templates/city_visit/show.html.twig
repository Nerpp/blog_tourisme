{% extends 'base.html.twig' %}

{% block title %}{{ city_visit.title }} - Visite de ville{% endblock %}

{% block body %}
    {% set cover_media = null %}

    {% for mediaLink in city_visit.mediaLinks %}
        {% set media = mediaLink.mediaAsset %}

        {% if cover_media is null and media and media.mediaType.value == 'image' %}
            {% set cover_media = media %}
        {% endif %}
    {% endfor %}

    {% set cover_image = null %}

    {% if cover_media %}
        {% set cover_image = cover_media.thumbnailPath ?: cover_media.filePath ?: cover_media.externalUrl %}
    {% endif %}

    {% set public_destination = city_visit.destination %}
    {% set public_destination_name = public_destination ? public_destination.name : city_visit.detectedCommuneName %}
    {% set public_department_name = city_visit.detectedDepartmentName %}
    {% set public_region_name = city_visit.detectedRegionName %}

    {% if public_destination %}
        {% set destination_node = public_destination %}
        {% if destination_node.type.value == 'department' %}
            {% set public_department_name = destination_node.name %}
        {% elseif destination_node.type.value == 'region' %}
            {% set public_region_name = destination_node.name %}
        {% endif %}

        {% set destination_node = destination_node.parent %}
        {% if destination_node %}
            {% if destination_node.type.value == 'department' %}
                {% set public_department_name = destination_node.name %}
            {% elseif destination_node.type.value == 'region' %}
                {% set public_region_name = destination_node.name %}
            {% endif %}
        {% endif %}

        {% set destination_node = destination_node ? destination_node.parent : null %}
        {% if destination_node %}
            {% if destination_node.type.value == 'department' %}
                {% set public_department_name = destination_node.name %}
            {% elseif destination_node.type.value == 'region' %}
                {% set public_region_name = destination_node.name %}
            {% endif %}
        {% endif %}

        {% set destination_node = destination_node ? destination_node.parent : null %}
        {% if destination_node and destination_node.type.value == 'region' %}
            {% set public_region_name = destination_node.name %}
        {% endif %}
    {% endif %}

    <main class="public-detail-page">
        <section class="public-detail-hero">
            <div class="public-detail-container public-detail-hero-grid">
                <div>
                    <p class="public-detail-kicker">Visite de ville</p>

                    <h1 class="public-detail-title">{{ city_visit.title }}</h1>

                    {% if is_granted('EDIT', city_visit) %}
                        <div class="show-admin-actions">
                            <a href="{{ path('admin_studio_city_visit_edit', { id: city_visit.id }) }}" class="show-admin-edit-link">Modifier</a>
                        </div>
                    {% endif %}

                    {% if city_visit.notes %}
                        <p class="public-detail-intro">{{ city_visit.notes|nl2br }}</p>
                    {% endif %}

                    <div class="public-detail-meta">
                        {% if public_destination_name %}
                            <span>{{ public_destination_name }}</span>
                        {% endif %}

                        {% if public_department_name and public_department_name != public_destination_name %}
                            <span>{{ public_department_name }}</span>
                        {% endif %}

                        {% if public_region_name and public_region_name not in [public_destination_name, public_department_name] %}
                            <span>{{ public_region_name }}</span>
                        {% endif %}

                        <span>{{ city_visit.points|length }} étape{{ city_visit.points|length > 1 ? 's' : '' }}</span>
                    </div>
                </div>

                <div
                    class="public-detail-cover"
                    {% if cover_image %}
                        {% set cover_image_url = cover_image starts with 'http' ? cover_image : asset(cover_image) %}
                        style="--public-cover-image: url('{{ cover_image_url|e('html_attr') }}');"
                    {% endif %}
                    aria-label="Image principale de la visite de ville"
                ></div>
            </div>
        </section>

        <section class="public-detail-content">
            <div class="public-detail-container">
                {% include 'public_detail/_media_sections.html.twig' with {
                    item: city_visit,
                    item_title: city_visit.title,
                    gallery_id: 'city-visit-gallery-' ~ city_visit.id,
                    photos_title: 'Photos de la visite',
                    photos_description: 'Les images classiques du lieu, utiles pour ressentir l’ambiance générale de la visite.',
                    video_kicker: 'Vidéo',
                    videos_title: 'Vidéos de la visite',
                    videos_description: 'Les vidéos permettent de visualiser l’ambiance, les rues, les accès et les points d’intérêt.',
                    video_fallback_title: 'Vidéo de la visite',
                    points_title: 'Étapes de la visite'
                } only %}
            </div>
        </section>
    </main>
{% endblock %}
