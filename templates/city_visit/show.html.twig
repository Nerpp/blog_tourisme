{% extends 'base.html.twig' %}

{% block title %}{{ city_visit.title }} - Visite de ville{% endblock %}

{% block body %}
    <main class="public-detail-page">
        <section class="public-detail-hero">
            <div class="public-detail-container">
                <p class="public-detail-kicker">Visite de ville</p>
                <h1>{{ city_visit.title }}</h1>

                {% if city_visit.notes %}
                    <p class="public-detail-intro">{{ city_visit.notes|nl2br }}</p>
                {% endif %}
            </div>
        </section>

        <section class="public-detail-section">
            <div class="public-detail-container">
                {% if city_visit.mediaLinks|length > 0 %}
                    <div class="public-media-grid">
                        {% for mediaLink in city_visit.mediaLinks %}
                            {% set media = mediaLink.mediaAsset %}
                            {% set image = media.thumbnailPath ?: media.filePath ?: media.externalUrl %}

                            {% if image %}
                                <figure class="public-media-card">
                                    <img src="{{ asset(image) }}" alt="{{ media.altText ?: city_visit.title }}">
                                </figure>
                            {% endif %}
                        {% endfor %}
                    </div>
                {% endif %}

                <h2>Étapes de la visite</h2>

                <div class="public-point-list">
                    {% for point in city_visit.points %}
                        <article class="public-point-card">
                            <p class="public-point-position">Étape {{ point.position }}</p>
                            <h3>{{ point.title ?: point.type.value }}</h3>

                            {% if point.note %}
                                <p>{{ point.note|nl2br }}</p>
                            {% endif %}
                        </article>
                    {% else %}
                        <p>Aucune étape détaillée pour le moment.</p>
                    {% endfor %}
                </div>
            </div>
        </section>
    </main>
{% endblock %}