        suggestions_id: 'city-visit-search-suggestions',
        search_label: 'Rechercher dans les visites',
        search_placeholder: 'Rechercher une visite, une ville, un quartier…',
        quick_filters: [],
        results_kicker: 'Parcours urbains',
        results_title: 'Visites de ville et points d’intérêt',
