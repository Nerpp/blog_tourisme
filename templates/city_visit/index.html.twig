{% extends 'layouts/listing.html.twig' %}

{% block title %}Visites - Blog Tourisme{% endblock %}
{% block meta_description %}Toutes les visites de ville publiées : parcours urbains, monuments, points d’intérêt et conseils pratiques.{% endblock %}

{% block body %}
    {% include 'public_listing/_content_list.html.twig' with {
        content_type: 'city-visits',
