{% set fallback_src = media_cover_image_url(media, 'medium', 'fallback') %}
{% set webp_srcset = media_cover_image_srcset(media, 'webp') %}
{% set fallback_srcset = media_cover_image_srcset(media, 'fallback') %}
{% set is_standard_image = media.mediaType.value == 'image' and media.imageType and media.imageType.value == 'standard' %}
{% set img_srcset = is_standard_image ? webp_srcset : fallback_srcset %}
{% set dimensions = media_cover_image_dimensions(media, 'medium') %}

{% if fallback_src %}
    <picture class="public-detail-cover__picture">
        {% if webp_srcset and not is_standard_image %}
            <source type="image/webp" srcset="{{ webp_srcset }}" sizes="{{ sizes }}">
        {% endif %}

        <img
            class="public-detail-cover__image"
            src="{{ fallback_src }}"
            alt="{{ alt }}"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            {% if img_srcset %}
                srcset="{{ img_srcset }}"
                sizes="{{ sizes }}"
            {% endif %}
            {% if dimensions %}
                width="{{ dimensions.width }}"
                height="{{ dimensions.height }}"
            {% endif %}
        >
    </picture>
{% endif %}
