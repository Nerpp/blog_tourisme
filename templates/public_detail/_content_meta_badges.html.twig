{% set public_destination_name = destination|default(null) ? destination.name : null %}
{% set public_commune_name = detected_commune_name|default(null) %}
{% set public_department_name = detected_department_name|default(null) %}
{% set public_region_name = detected_region_name|default(null) %}

{% if destination|default(null) %}
    {% set destination_node = destination %}
    {% if destination_node.type.value == 'department' %}
        {% set public_department_name = destination_node.name %}
    {% elseif destination_node.type.value == 'region' %}
        {% set public_region_name = destination_node.name %}
    {% endif %}

    {% set destination_node = destination_node.parent %}
    {% if destination_node %}
        {% if destination_node.type.value == 'department' %}
            {% set public_department_name = destination_node.name %}
        {% elseif destination_node.type.value == 'region' %}
            {% set public_region_name = destination_node.name %}
        {% endif %}
    {% endif %}

    {% set destination_node = destination_node ? destination_node.parent : null %}
    {% if destination_node %}
        {% if destination_node.type.value == 'department' %}
            {% set public_department_name = destination_node.name %}
        {% elseif destination_node.type.value == 'region' %}
            {% set public_region_name = destination_node.name %}
        {% endif %}
    {% endif %}

    {% set destination_node = destination_node ? destination_node.parent : null %}
    {% if destination_node %}
        {% if destination_node.type.value == 'department' %}
            {% set public_department_name = destination_node.name %}
        {% elseif destination_node.type.value == 'region' %}
            {% set public_region_name = destination_node.name %}
        {% endif %}
    {% endif %}
{% endif %}

{% set public_destination_label = public_destination_name|default('')|trim %}
{% set public_commune_label = public_commune_name|default('')|trim %}
{% set public_department_label = public_department_name|default('')|trim %}
{% set public_region_label = public_region_name|default('')|trim %}
{% set public_destination_key = public_destination_label|lower %}
{% set public_commune_key = public_commune_label|lower %}
{% set public_department_key = public_department_label|lower %}
{% set public_region_key = public_region_label|lower %}
{% set points_label = points_count|default(0) > 1 ? 'étapes' : 'étape' %}

<div class="public-detail-meta">
    {% if public_commune_label is not empty %}
        <span>Commune : {{ public_commune_label }}</span>
    {% endif %}

    {% if public_destination_label is not empty %}
        <span>Destination : {{ public_destination_label }}</span>
    {% endif %}

    {% if public_department_label is not empty
        and public_department_key != public_destination_key
        and public_department_key != public_commune_key
    %}
        <span>{{ public_department_label }}</span>
    {% endif %}

    {% if public_region_label is not empty
        and public_region_key not in [public_destination_key, public_commune_key, public_department_key]
    %}
        <span>{{ public_region_label }}</span>
    {% endif %}

    {% if points_count is defined and points_count is not null %}
        <span>{{ points_count }} {{ points_label }}</span>
    {% endif %}
</div>
