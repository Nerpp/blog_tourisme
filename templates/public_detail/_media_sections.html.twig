{% set standard_media_links = [] %}
{% set video_media_links = [] %}
{% set immersive_media_links = [] %}
{% set panorama_media_links = [] %}
{% set immersive_gallery_links = [] %}
{% set gps_point_type = gps_point_type|default(null) %}
{% set valid_gps_points = [] %}

{% for mediaLink in item.mediaLinks %}
    {% set media = mediaLink.mediaAsset %}

    {% if media %}
        {% if media.mediaType.value == 'video' %}
            {% set video_media_links = video_media_links|merge([mediaLink]) %}
        {% elseif media.imageType and media.imageType.value in ['360', '180'] %}
            {% set immersive_media_links = immersive_media_links|merge([mediaLink]) %}
            {% set immersive_gallery_links = immersive_gallery_links|merge([mediaLink]) %}
        {% elseif media.imageType and media.imageType.value == 'panorama' %}
            {% set panorama_media_links = panorama_media_links|merge([mediaLink]) %}
            {% set immersive_gallery_links = immersive_gallery_links|merge([mediaLink]) %}
        {% else %}
            {% set standard_media_links = standard_media_links|merge([mediaLink]) %}
        {% endif %}
    {% endif %}
{% endfor %}

{% for point in item.points %}
    {% if point.latitude is not null and point.longitude is not null %}
        {% set valid_gps_points = valid_gps_points|merge([point]) %}
    {% endif %}
{% endfor %}

{% if standard_media_links|length > 0 %}
    <section id="{{ gallery_id }}-photos" class="media-section">
        <div class="media-header">
            <div>
                <p class="media-kicker">Parcours</p>
                <h2 class="media-title">{{ photos_title }}</h2>
                <p class="media-description">
                    {{ photos_description }}
                </p>
            </div>

            <div class="media-actions">
                <span class="media-count">{{ standard_media_links|length }}</span>

                <button
                    type="button"
                    class="media-visualize-btn"
                    data-gallery-target="#{{ gallery_id }}"
                    data-gallery-index="0"
                >
                    Visualiser
                </button>
            </div>
        </div>

        <div class="journey-gallery">
            {% for mediaLink in standard_media_links|slice(0, 5) %}
                {% set media = mediaLink.mediaAsset %}

                {% if media %}
                    {% set image_url = media_image_url(media, 'thumb') %}

                    {% if image_url %}
                        {% set card_sizes = loop.first ? '(min-width: 900px) 50vw, 90vw' : '(min-width: 900px) 25vw, 45vw' %}

                        <figure class="journey-gallery-card {{ loop.first ? 'journey-gallery-card--large' : '' }}">
                            <button
                                type="button"
                                class="media-badge"
                                data-gallery-target="#{{ gallery_id }}"
                                data-gallery-index="{{ loop.index0 }}"
                            >
                                Photo
                            </button>

                            {% include 'public_detail/_responsive_image.html.twig' with {
                                media: media,
                                alt: media_public_alt(media, item, item_title),
                                image_size: loop.first ? 'medium' : 'thumb',
                                sizes: card_sizes
                            } only %}

                            {% if loop.index == 5 and standard_media_links|length > 5 %}
                                <span class="journey-gallery-card__more">
                                    +{{ standard_media_links|length - 5 }} photo{{ standard_media_links|length - 5 > 1 ? 's' : '' }}
                                </span>
                            {% endif %}
                        </figure>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>

        <div
            id="{{ gallery_id }}"
            class="gallery-modal js-gallery-modal"
            role="dialog"
            aria-modal="true"
            aria-hidden="true"
            aria-labelledby="{{ gallery_id }}-title"
            hidden
        >
            <div class="gallery-modal__dialog" role="document">
                <header class="gallery-modal__header">
                    <div>
                        <h2 id="{{ gallery_id }}-title" class="gallery-modal__title">
                            {{ photos_title }}
                        </h2>

                        <div class="gallery-modal__counter js-gallery-counter">
                            1 / {{ standard_media_links|length }}
                        </div>
                    </div>

                    <button
                        type="button"
                        class="gallery-modal__close js-gallery-close"
                        aria-label="Fermer la galerie"
                    >
                        ×
                    </button>
                </header>

                <div class="gallery-modal__body">
                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--prev js-gallery-prev"
                        aria-label="Photo précédente"
                    >
                        ‹
                    </button>

                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--next js-gallery-next"
                        aria-label="Photo suivante"
                    >
                        ›
                    </button>

                    {% for mediaLink in standard_media_links %}
                        {% set media = mediaLink.mediaAsset %}

                        {% if media %}
                            {% set image_url = media_modal_url(media) %}

                            {% if image_url %}
                                {% set has_caption = media.caption is not empty %}

                                <article class="gallery-modal__slide js-gallery-slide {{ has_caption ? 'gallery-modal__slide--with-comment' : 'gallery-modal__slide--image-only' }} {{ loop.first ? 'is-active' : '' }}">
                                    <figure class="gallery-modal__media">
                                        <img
                                            data-gallery-src="{{ image_url }}"
                                            alt="{{ media_public_alt(media, item, item_title) }}"
                                            decoding="async"
                                            {% if media.width and media.height %}
                                                width="{{ media.width }}"
                                                height="{{ media.height }}"
                                            {% endif %}
                                        >
                                    </figure>

                                    {% if has_caption %}
                                        <div class="gallery-modal__caption">
                                            <p>{{ media.caption|nl2br }}</p>
                                        </div>
                                    {% endif %}
                                </article>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>

                <footer class="gallery-modal__footer" aria-label="Navigation galerie">
                    {% for mediaLink in standard_media_links %}
                        <button
                            type="button"
                            class="gallery-modal__dot js-gallery-dot {{ loop.first ? 'is-active' : '' }}"
                            aria-label="Afficher la photo {{ loop.index }}"
                            aria-current="{{ loop.first ? 'true' : 'false' }}"
                        ></button>
                    {% endfor %}
                </footer>
            </div>
        </div>
    </section>
{% endif %}

{% if video_media_links|length > 0 %}
    <section id="{{ gallery_id }}-videos" class="media-section media-section--dark">
        <div class="media-header">
            <div>
                <p class="media-kicker">{{ video_kicker }}</p>
                <h2 class="media-title">{{ videos_title }}</h2>
                <p class="media-description">
                    {{ videos_description }}
                </p>
            </div>

            <div class="media-actions">
                <span class="media-count">{{ video_media_links|length }}</span>

                <button
                    type="button"
                    class="media-visualize-btn"
                    data-gallery-target="#{{ gallery_id }}-video-gallery"
                    data-gallery-index="0"
                >
                    Visualiser
                </button>
            </div>
        </div>

        <div class="video-gallery-grid">
            {% for mediaLink in video_media_links|slice(0, 5) %}
                {% set media = mediaLink.mediaAsset %}

                {% if media %}
                    {% set local_video = media.filePath %}
                    {% set embed_url = media|video_embed_url %}
                    {% set external_video = media.externalUrl %}
                    {% set poster_url = media_poster_url(media, 'medium') %}

                    {% if embed_url or local_video or external_video %}
                        <button
                            type="button"
                            class="video-gallery-card {{ loop.first ? 'video-gallery-card--large' : '' }} {{ poster_url ? 'has-poster' : 'has-placeholder' }}"
                            aria-label="Afficher la vidéo en grand"
                            data-gallery-target="#{{ gallery_id }}-video-gallery"
                            data-gallery-index="{{ loop.index0 }}"
                        >
                            <span class="video-gallery-card__badge">Vidéo</span>

                            {% if poster_url %}
                                <img
                                    src="{{ poster_url }}"
                                    alt="{{ media_public_alt(media, item, media_public_title(media, item, video_fallback_title)) }}"
                                    loading="lazy"
                                    decoding="async"
                                >
                                <span class="video-gallery-card__play" aria-hidden="true">▶</span>
                            {% else %}
                                <span class="video-gallery-card__placeholder">
                                    <span class="video-gallery-card__play" aria-hidden="true">▶</span>
                                    <span class="video-gallery-card__title">{{ media_public_title(media, item, video_fallback_title) }}</span>
                                </span>
                            {% endif %}

                            {% if loop.index == 5 and video_media_links|length > 5 %}
                                <span class="video-gallery-card__more">
                                    +{{ video_media_links|length - 5 }} vidéo{{ video_media_links|length - 5 > 1 ? 's' : '' }}
                                </span>
                            {% endif %}
                        </button>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>

        <div
            id="{{ gallery_id }}-video-gallery"
            class="gallery-modal js-gallery-modal"
            role="dialog"
            aria-modal="true"
            aria-hidden="true"
            aria-labelledby="{{ gallery_id }}-video-gallery-title"
            hidden
        >
            <div class="gallery-modal__dialog gallery-modal__dialog--video" role="document">
                <header class="gallery-modal__header">
                    <div>
                        <h2 id="{{ gallery_id }}-video-gallery-title" class="gallery-modal__title">
                            {{ videos_title }}
                        </h2>

                        <div class="gallery-modal__counter js-gallery-counter">
                            1 / {{ video_media_links|length }}
                        </div>
                    </div>

                    <button
                        type="button"
                        class="gallery-modal__close js-gallery-close"
                        aria-label="Fermer la galerie"
                    >
                        ×
                    </button>
                </header>

                <div class="gallery-modal__body">
                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--prev js-gallery-prev"
                        aria-label="Vidéo précédente"
                    >
                        ‹
                    </button>

                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--next js-gallery-next"
                        aria-label="Vidéo suivante"
                    >
                        ›
                    </button>

                    {% for mediaLink in video_media_links %}
                        {% set media = mediaLink.mediaAsset %}

                        {% if media %}
                            {% set local_video = media.filePath %}
                            {% set embed_url = media|video_embed_url %}
                            {% set external_video = media.externalUrl %}
                            {% set poster_url = media_poster_url(media, 'medium') %}
                            {% set has_caption = media.caption is not empty %}

                            {% if embed_url or local_video or external_video %}
                                <article class="gallery-modal__slide gallery-modal__slide--video js-gallery-slide {{ has_caption ? 'gallery-modal__slide--with-comment' : 'gallery-modal__slide--image-only' }} {{ loop.first ? 'is-active' : '' }}">
                                    <figure class="gallery-modal__media gallery-modal__video-frame">
                                        {% if embed_url %}
                                            <iframe
                                                data-video-src="{{ embed_url }}"
                                                title="{{ media_public_title(media, item, item_title) }}"
                                                loading="lazy"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                referrerpolicy="strict-origin-when-cross-origin"
                                                allowfullscreen
                                            ></iframe>
                                        {% elseif local_video %}
                                            {% set local_video_url = local_video starts with 'http' ? local_video : asset(local_video) %}
                                            <video
                                                controls
                                                playsinline
                                                preload="none"
                                                data-video-src="{{ local_video_url }}"
                                                data-video-type="{{ media.mimeType ?: 'video/mp4' }}"
                                                {% if poster_url %}
                                                    poster="{{ poster_url }}"
                                                {% endif %}
                                            >
                                                Votre navigateur ne supporte pas la lecture vidéo.
                                            </video>
                                        {% elseif external_video %}
                                            <a
                                                class="video-external-link"
                                                href="{{ external_video }}"
                                                target="_blank"
                                                rel="noopener noreferrer"
                                            >
                                                Ouvrir la vidéo
                                            </a>
                                        {% endif %}
                                    </figure>

                                    {% if has_caption %}
                                        <div class="gallery-modal__caption gallery-modal__caption--video">
                                            <p>{{ media.caption|nl2br }}</p>
                                        </div>
                                    {% endif %}
                                </article>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>

                <footer class="gallery-modal__footer" aria-label="Navigation vidéos">
                    {% for mediaLink in video_media_links %}
                        <button
                            type="button"
                            class="gallery-modal__dot js-gallery-dot {{ loop.first ? 'is-active' : '' }}"
                            aria-label="Afficher la vidéo {{ loop.index }}"
                            aria-current="{{ loop.first ? 'true' : 'false' }}"
                        ></button>
                    {% endfor %}
                </footer>
            </div>
        </div>
    </section>
{% endif %}

{% if immersive_gallery_links|length > 0 %}
    <section id="{{ gallery_id }}-immersive" class="media-section">
        <div class="media-header">
            <div>
                <p class="media-kicker">Immersion</p>
                <h2 class="media-title">Vues immersives et panoramiques</h2>
                <p class="media-description">
                    Ouvrez les vues 360°, 180° et panoramas en grand pour explorer le paysage confortablement.
                </p>
            </div>

            <div class="media-actions">
                <span class="media-count">{{ immersive_gallery_links|length }}</span>

                <button
                    type="button"
                    class="media-visualize-btn"
                    data-gallery-target="#{{ gallery_id }}-immersive-gallery"
                    data-gallery-index="0"
                >
                    Visualiser
                </button>
            </div>
        </div>

        <div class="immersive-gallery-grid">
            {% for mediaLink in immersive_gallery_links|slice(0, 5) %}
                {% set media = mediaLink.mediaAsset %}

                {% if media %}
                    {% set image_type = media.imageType ? media.imageType.value : 'standard' %}
                    {% set badge_label = image_type == '360' ? '360°' : (image_type == '180' ? '180°' : 'Panorama') %}
                    {% set image_url = media_image_url(media, loop.first ? 'medium' : 'thumb') %}

                    {% if image_url %}
                        <button
                            type="button"
                            class="immersive-gallery-card {{ loop.first ? 'immersive-gallery-card--large' : '' }}"
                            aria-label="Afficher la vue {{ badge_label }} en grand"
                            data-gallery-target="#{{ gallery_id }}-immersive-gallery"
                            data-gallery-index="{{ loop.index0 }}"
                        >
                            <span class="immersive-gallery-card__badge">{{ badge_label }}</span>

                            {% include 'public_detail/_responsive_image.html.twig' with {
                                media: media,
                                alt: media_public_alt(media, item, item_title),
                                image_size: loop.first ? 'medium' : 'thumb',
                                sizes: loop.first ? '(min-width: 900px) 50vw, 90vw' : '(min-width: 900px) 25vw, 45vw'
                            } only %}

                            {% if loop.index == 5 and immersive_gallery_links|length > 5 %}
                                <span class="immersive-gallery-card__more">
                                    +{{ immersive_gallery_links|length - 5 }} vue{{ immersive_gallery_links|length - 5 > 1 ? 's' : '' }}
                                </span>
                            {% endif %}
                        </button>
                    {% endif %}
                {% endif %}
            {% endfor %}
        </div>

        <div
            id="{{ gallery_id }}-immersive-gallery"
            class="gallery-modal js-gallery-modal"
            role="dialog"
            aria-modal="true"
            aria-hidden="true"
            aria-labelledby="{{ gallery_id }}-immersive-gallery-title"
            hidden
        >
            <div class="gallery-modal__dialog gallery-modal__dialog--immersive" role="document">
                <header class="gallery-modal__header">
                    <div>
                        <h2 id="{{ gallery_id }}-immersive-gallery-title" class="gallery-modal__title">
                            Vues immersives et panoramiques
                        </h2>

                        <div class="gallery-modal__counter js-gallery-counter">
                            1 / {{ immersive_gallery_links|length }}
                        </div>
                    </div>

                    <button
                        type="button"
                        class="gallery-modal__close js-gallery-close"
                        aria-label="Fermer la galerie"
                    >
                        ×
                    </button>
                </header>

                <div class="gallery-modal__body">
                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--prev js-gallery-prev"
                        aria-label="Vue précédente"
                    >
                        ‹
                    </button>

                    <button
                        type="button"
                        class="gallery-modal__nav gallery-modal__nav--next js-gallery-next"
                        aria-label="Vue suivante"
                    >
                        ›
                    </button>

                    {% for mediaLink in immersive_gallery_links %}
                        {% set media = mediaLink.mediaAsset %}

                        {% if media %}
                            {% set image_type = media.imageType ? media.imageType.value : 'standard' %}
                            {% set is_360 = image_type == '360' %}
                            {% set is_panorama = image_type == 'panorama' %}
                            {% set has_caption = media.caption is not empty %}
                            {% set image_url = media_modal_url(media) ?: media_image_url(media, 'large') %}
                            {% set preview_url = media_image_url(media, 'thumb') ?: media_image_url(media, 'medium') %}
                            {% set panorama = media.filePath ?: media.externalUrl %}
                            {% set mobile_panorama = media.metadata and media.metadata.mobilePath is defined ? media.metadata.mobilePath : null %}

                            {% if is_360 and panorama %}
                                {% set panorama_url = panorama starts with 'http' ? panorama : asset(panorama) %}
                                {% set mobile_panorama_url = mobile_panorama ? (mobile_panorama starts with 'http' ? mobile_panorama : asset(mobile_panorama)) : null %}

                                <article class="gallery-modal__slide gallery-modal__slide--immersive gallery-modal__slide--viewer360 js-gallery-slide {{ has_caption ? 'gallery-modal__slide--with-comment' : 'gallery-modal__slide--image-only' }} {{ loop.first ? 'is-active' : '' }}">
                                    <div
                                        class="js-panorama-viewer trail-panorama-viewer trail-panorama-viewer--modal"
                                        data-panorama-url="{{ panorama_url }}"
                                        {% if mobile_panorama_url %}data-panorama-mobile-url="{{ mobile_panorama_url }}"{% endif %}
                                        aria-label="Vue panoramique 360 degrés"
                                    >
                                        <div class="trail-panorama-fallback" data-panorama-fallback>
                                            {% if preview_url %}
                                                <img
                                                    data-gallery-src="{{ preview_url }}"
                                                    alt="{{ media_public_alt(media, item, 'Aperçu de la vue 360°') }}"
                                                    decoding="async"
                                                >
                                            {% endif %}
                                            <p data-panorama-fallback-message>La vue 360° n’est pas disponible sur cet appareil, mais vous pouvez consulter l’image en aperçu.</p>
                                        </div>
                                    </div>

                                    {% if has_caption %}
                                        <div class="gallery-modal__caption gallery-modal__caption--immersive">
                                            <p>{{ media.caption|nl2br }}</p>
                                        </div>
                                    {% endif %}
                                </article>
                            {% elseif image_url %}
                                <article class="gallery-modal__slide gallery-modal__slide--immersive {{ is_panorama ? 'gallery-modal__slide--panorama' : '' }} js-gallery-slide {{ has_caption ? 'gallery-modal__slide--with-comment' : 'gallery-modal__slide--image-only' }} {{ loop.first ? 'is-active' : '' }}">
                                    <figure class="gallery-modal__media gallery-modal__media--immersive {{ is_panorama ? 'gallery-modal__media--panorama' : '' }}">
                                        <img
                                            data-gallery-src="{{ image_url }}"
                                            alt="{{ media_public_alt(media, item, item_title) }}"
                                            decoding="async"
                                            {% if media.width and media.height %}
                                                width="{{ media.width }}"
                                                height="{{ media.height }}"
                                            {% endif %}
                                        >
                                    </figure>

                                    {% if has_caption %}
                                        <div class="gallery-modal__caption gallery-modal__caption--immersive">
                                            <p>{{ media.caption|nl2br }}</p>
                                        </div>
                                    {% endif %}
                                </article>
                            {% endif %}
                        {% endif %}
                    {% endfor %}
                </div>

                <footer class="gallery-modal__footer" aria-label="Navigation vues immersives">
                    {% for mediaLink in immersive_gallery_links %}
                        <button
                            type="button"
                            class="gallery-modal__dot js-gallery-dot {{ loop.first ? 'is-active' : '' }}"
                            aria-label="Afficher la vue {{ loop.index }}"
                            aria-current="{{ loop.first ? 'true' : 'false' }}"
                        ></button>
                    {% endfor %}
                </footer>
            </div>
        </div>
    </section>
{% endif %}

<section id="{{ gallery_id }}-points" class="media-section public-point-section">
    <div class="media-header">
        <div>
            <p class="media-kicker">Itinéraire</p>
            <h2 class="media-title">{{ points_title }}</h2>
        </div>

        <span class="media-count">{{ item.points|length }}</span>
    </div>

    {% if valid_gps_points|length > 0 %}
        {% set gps_access_point = valid_gps_points|first %}

        <div class="public-route-gps">
            {% if gps_point_type and is_granted('GPS_ACCESS', gps_access_point) %}
                <div class="public-route-gps__actions">
                    <a
                        class="public-point-gps__button"
                        href="{{ path('app_gps_start_open', { type: gps_point_type, id: item.id }) }}"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        Aller au départ
                    </a>

                    <a
                        class="public-point-gps__button public-point-gps__button--secondary"
                        href="{{ path('app_gps_route_open', { type: gps_point_type, id: item.id }) }}"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        Parcours Google Maps
                    </a>
                </div>

                <p class="public-route-gps__notice">
                    Conseil : avant de partir, téléchargez la zone dans Google Maps pour pouvoir naviguer même sans réseau.
                </p>
            {% elseif not is_granted('GPS_ACCESS', gps_access_point) %}
                <a
                    class="public-point-gps__cta"
                    href="{{ path('app_login') }}"
                >
                    Connectez-vous pour accéder à la navigation GPS
                </a>
            {% endif %}
        </div>
    {% endif %}

    <div class="public-point-list">
        {% for point in item.points %}
            <article class="public-point-card">
                <div>
                    <span class="public-point-number">
                        {{ '%02d'|format(loop.index) }}
                    </span>
                </div>

                <div>
                    <p class="public-point-type">{{ point.type.value }}</p>

                    <h3>{{ point.title ?: 'Étape ' ~ loop.index }}</h3>

                    {% if point.note %}
                        <p>{{ point.note|nl2br }}</p>
                    {% endif %}

                    {% if point.latitude is not null and point.longitude is not null %}
                        <div class="public-point-gps">
                            {% if gps_point_type and is_granted('GPS_ACCESS', point) %}
                                <a
                                    class="public-point-gps__button"
                                    href="{{ path('app_gps_point_open', { type: gps_point_type, id: point.id }) }}"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                >
                                    Voir ce point
                                </a>
                            {% elseif not is_granted('GPS_ACCESS', point) %}
                                <a
                                    class="public-point-gps__cta"
                                    href="{{ path('app_login') }}"
                                >
                                    Connectez-vous pour ouvrir ce point sur la carte
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}

                    {% if point.mediaLinks|length > 0 %}
                        <div class="point-media-grid">
                            {% for pointMediaLink in point.mediaLinks %}
                                {% set media = pointMediaLink.mediaAsset %}

                                {% if media %}
                                    {% set image_url = media_image_url(media, 'thumb') %}

                                    {% if image_url and media.mediaType.value == 'image' %}
                                        <figure class="point-media-card">
                                            {% if media.imageType and media.imageType.value in ['360', '180'] %}
                                                <span class="point-media-card__badge">{{ media.imageType.value == '360' ? '360°' : '180°' }}</span>
                                            {% endif %}

                                            {% include 'public_detail/_responsive_image.html.twig' with {
                                                media: media,
                                                alt: media_public_alt(media, item, point.title ?: item_title),
                                                image_size: 'thumb',
                                                sizes: '(min-width: 760px) 240px, 45vw'
                                            } only %}

                                            {% set point_media_title = media_public_title(media, item, point.title ?: item_title) %}
                                            {% if media.caption or point_media_title %}
                                                <figcaption>{{ media.caption ?: point_media_title }}</figcaption>
                                            {% endif %}
                                        </figure>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <p class="empty-media-note">Aucune étape détaillée pour le moment.</p>
        {% endfor %}
    </div>
