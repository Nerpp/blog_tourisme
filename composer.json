{
    "name": "app/blog-tourisme",
    "description": "Symfony local development project with Docker, Vite, Vue 3 and Vuetify.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo_mysql": "*",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.3",
        "knpuniversity/oauth2-client-bundle": "^2.20",
        "league/oauth2-google": "^5.0",
        "symfony/asset": "8.1.*",
        "symfony/cache": "8.1.*",
        "symfony/config": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dependency-injection": "8.1.*",
        "symfony/doctrine-bridge": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/error-handler": "8.1.*",
        "symfony/event-dispatcher": "8.1.*",
        "symfony/filesystem": "8.1.*",
        "symfony/finder": "8.1.*",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "^8.0",
        "symfony/http-foundation": "8.1.*",
        "symfony/http-kernel": "8.1.*",
        "symfony/mailer": "8.1.*",
        "symfony/mime": "8.1.*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/rate-limiter": "8.1.*",
        "symfony/routing": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/security-bundle": "8.1.*",
        "symfony/security-csrf": "8.1.*",
        "symfony/stopwatch": "8.1.*",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bridge": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/validator": "8.1.*",
        "symfony/var-dumper": "8.1.*",
        "symfony/var-exporter": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/reset-password-bundle": "^1.25",
        "symfonycasts/verify-email-bundle": "^1.18"
    },
    "require-dev": {
        "dama/doctrine-test-bundle": "^8.6",
        "dbrekelmans/bdi": "^1.4",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "symfony/maker-bundle": "^1.67",
        "symfony/panther": "^2.4",
        "symfony/profiler-pack": "^1.0",
        "symfony/test-pack": "^1.2",
        "symfony/web-profiler-bundle": "8.1.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": [
            "@test:db:reset",
            "APP_ENV=test php vendor/bin/phpunit --testsuite Unit,Integration,Functional"
        ],
        "test:unit": "APP_ENV=test php vendor/bin/phpunit --testsuite Unit",
        "test:integration": [
            "@test:db:reset",
            "APP_ENV=test php vendor/bin/phpunit --testsuite Integration"
        ],
        "test:functional": [
            "@test:db:reset",
            "APP_ENV=test php vendor/bin/phpunit --testsuite Functional"
        ],
        "test:e2e": [
            "@test:db:reset",
            "APP_ENV=test php vendor/bin/phpunit --testsuite E2E"
        ],
        "test:panther": "@test:e2e",
        "test:db:reset": "scripts/reset-test-database-in-container.sh",
        "lighthouse:test-db:assert-safe": "php bin/console app:test-database:assert-safe --env=test",
        "lighthouse:test-db:reset": [
            "php bin/console cache:clear --env=test --no-warmup",
            "@test:db:reset",
            "php bin/console cache:clear --env=test --no-warmup",
            "@lighthouse:test-db:assert-safe"
        ],
        "test:coverage": [
            "@test:db:reset",
            "APP_ENV=test XDEBUG_MODE=coverage php vendor/bin/phpunit --testsuite Unit,Integration,Functional --coverage-text --coverage-html var/coverage"
        ],
        "test:coverage:clover": [
            "@test:db:reset",
            "APP_ENV=test XDEBUG_MODE=coverage php vendor/bin/phpunit --testsuite Unit,Integration,Functional --coverage-clover var/coverage/clover.xml"
        ],
        "quality": [
            "php bin/console lint:container",
            "php bin/console lint:twig templates",
            "@test"
        ],
        "quality:e2e": [
            "@quality",
            "@test:e2e"
        ],
        "quality:frontend": "npm run build"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "require": "8.1.*"
        }
    }
}
