{
    "name": "app/blog-tourisme",
    "description": "Symfony local development project with Docker, Vite, Vue 3 and Vuetify.",
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-pdo_mysql": "*",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.3",
        "knpuniversity/oauth2-client-bundle": "^2.20",
        "league/oauth2-google": "^5.0",
        "symfony/asset": "8.0.*",
        "symfony/cache": "8.0.*",
        "symfony/config": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/dependency-injection": "8.0.*",
        "symfony/doctrine-bridge": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/error-handler": "8.0.*",
        "symfony/event-dispatcher": "8.0.*",
        "symfony/filesystem": "8.0.*",
        "symfony/finder": "8.0.*",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "^8.0",
        "symfony/http-foundation": "8.0.*",
        "symfony/http-kernel": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/rate-limiter": "8.0.*",
        "symfony/routing": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/security-csrf": "8.0.*",
        "symfony/stopwatch": "8.0.*",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bridge": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/validator": "8.0.*",
        "symfony/var-dumper": "8.0.*",
        "symfony/var-exporter": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/reset-password-bundle": "^1.25",
        "symfonycasts/verify-email-bundle": "^1.18"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "symfony/maker-bundle": "^1.67",
        "symfony/profiler-pack": "^1.0",
        "symfony/test-pack": "^1.2",
        "symfony/web-profiler-bundle": "8.0.*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/phpunit",
        "test:unit": "php vendor/bin/phpunit --testsuite Unit",
        "test:functional": "php vendor/bin/phpunit --testsuite Functional",
        "quality": [
            "php bin/console lint:container",
            "php bin/console lint:twig templates",
            "php bin/console doctrine:schema:validate --skip-sync",
            "php vendor/bin/phpunit"
        ],
        "quality:frontend": "npm run build"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "extra": {
        "symfony": {
            "require": "8.0.*"
        }
    }
}
