APP_ENV=test
APP_DEBUG=1
APP_SECRET=test-secret
DATABASE_URL="mysql://app:app@mysql:3306/app_test?serverVersion=8.0&charset=utf8mb4"
DATABASE_URL_TEST="mysql://app:app@mysql:3306/app_test?serverVersion=8.0&charset=utf8mb4"
MAILER_DSN=null://null
COMMENT_AUTO_APPROVE_AFTER=3
COMMENT_REPORT_THRESHOLD=3
OAUTH_GOOGLE_CLIENT_ID=test-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=test-google-client-secret
PANTHER_APP_ENV=test
PANTHER_WEB_SERVER_DIR=./public
PANTHER_WEB_SERVER_PORT=9080
PANTHER_ERROR_SCREENSHOT_DIR=var/panther/screenshots
PANTHER_NO_SANDBOX=1
PANTHER_CHROME_BINARY=/usr/bin/chromium
PANTHER_CHROME_ARGUMENTS="--headless=new --no-sandbox --disable-gpu --disable-dev-shm-usage --window-size=1400,1000"
HOME=/tmp
XDG_CACHE_HOME=/tmp/panther-cache
XDG_CONFIG_HOME=/tmp/panther-config
